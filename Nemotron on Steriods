mport PeftModel, LoraConfig, get_peft_model\n","from transformers import AutoModelForCausalLM, AutoTokenizer\n","import datasets\n","\n","datasets.utils.logging.disable_progress_bar()\n","\n","BASE_MODEL_PATH = \"/kaggle/input/models/metric/nemotron-3-nano-30b-a3b-bf16/transformers/default/1\"\n","ADAPTER_3_PATH = \"/kaggle/input/datasets/banwait13/lora-adapter/NEMOTRON\"\n","\n","if 'model' not in globals() or model is None:\n","    print(\"[DAPO] Loading Base Model...\")\n","    model = AutoModelForCausalLM.from_pretrained(\n","        BASE_MODEL_PATH,\n","        device_map=\"auto\",\n","        torch_dtype=torch.bfloat16,\n","        trust_remote_code=True,\n","    )\n","    tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL_PATH, trust_remote_code=True)\n","    if tokenizer.unk_token is not None:\n","        tokenizer.pad_token = tokenizer.unk_token\n","    else:\n","        tokenizer.pad_token = tokenizer.eos_token\n","    tokenizer.padding_side = \"right\"\n","\n","    print(\"[DAPO] Attaching Adapter 3 as trainable...\")\n","    model = PeftModel.from_pretrained(model, ADAPTER_3_PATH, is_trainable=True)\n","    print(f\"[DAPO] Adapter loaded. Trainable params: {sum(p.numel() for p in model.parameters() if p.requires_grad):,}\")\n","else:\n","    print(\"[DAPO] Model already in memory.\")\n","\n","# ── NUCLEAR FIX: Manually apply gradient checkpointing ────────────────────\n","# NemotronHForCausalLM does not declare gradient checkpointing support,\n","# so gradient_checkpointing_enable() throws a ValueError.\n","# We bypass the method entirely and do what it does internally.\n","import functools as _ft\n","from torch.utils.checkpoint import checkpoint as _torch_ckpt\n","\n","model.config.use_cache = False\n","_gc_fn = _ft.partial(_torch_ckpt, use_reentrant=False)\n","for _m in model.modules():\n","    if hasattr(_m, 'gradient_checkpointing'):\n","        _m.gradient_checkpointing = True\n","    _m._gradient_checkpointing_func = _gc_fn\n","\n","if hasattr(model, \"enable_input_require_grads\"):\n","    model.enable_input_require_grads()\n","    \n","print(\"[DAPO] Gradient checkpointing force-applied (manual bypass).\")\n","\n","# ── Load dataset ─────────────────────────────────────────────────────────────\n","grpo_dataset = load_dataset(\n","    \"csv\",\n","    data_files=\"/kaggle/input/datasets/banwait13/lora-adapter/DATASETS/GRPO_TEST.csv\",\n","    split=\"train\",\n",")\n","\n","def normalize_cols(sample):\n","    question = (\n","        sample.get(\"instruction\") or sample.get(\"prompt\")\n","        or sample.get(\"question\") or \"\"\n","    )\n","    answer = (\n","        sample.get(\"response\") or sample.get(\"answer\")\n","        or sample.get(\"output\") or \"\"\n","    )\n","    ptype = (\n","        sample.get(\"puzzle_type\") or sample.get(\"type\") or \"unknown\"\n","    )\n","    return {\n","        \"question\":    str(question).strip(),\n","        \"answer\":      str(answer).strip(),\n","        \"puzzle_type\": str(ptype).strip().lower(),\n","    }\n","\n","grpo_dataset = grpo_dataset.map(normalize_cols, num_proc=2)\n","\n","# ── Curriculum ordering: easy → hard ─────────────────────────────────────────\n","# GRPO needs problems the model can sometimes solve early.\n","# All-miss groups → advantage=0 → zero gradient → wasted steps.\n","DIFFICULTY = {\n","    \"numeral\": 0, \"roman_numeral\": 0, \"roman numerals\": 0,\n","    \"equations\": 1, \"equation\": 1, \"algebra\": 1,\n","    \"gravity\": 2, \"physics\": 2,\n","    \"encryption\": 3, \"cipher\": 3,\n","    \"unit_conversion\": 4, \"unit conversion\": 4,\n","}\n","\n","grpo_pd = grpo_dataset.to_pandas()\n","grpo_pd[\"_diff\"] = grpo_pd[\"puzzle_type\"].apply(\n","    lambda p: next((v for k, v in DIFFICULTY.items() if k in str(p).lower()), 2)\n",")\n","grpo_pd = (\n","    grpo_pd.groupby(\"_diff\", group_keys=False)\n","           .apply(lambda g: g.sample(frac=1, random_state=3407))\n","           .sort_values(\"_diff\")\n","           .drop(columns=[\"_diff\"])\n","           .reset_index(drop=True)\n",")\n","grpo_dataset = Dataset.from_pandas(grpo_pd)\n","\n","keep = {\"question\", \"answer\", \"puzzle_type\"}\n","drop = [c for c in grpo_dataset.column_names if c not in keep]\n","if drop:\n","    grpo_dataset = grpo_dataset.remove_columns(drop)\n","\n","# ── Build prompts — NO <think> injection, aligned with eval engine ────────────\n","# The competition evaluator uses enable_thinking=True in apply_chat_template.\n","# Pre-injecting <think> misaligns training vs inference entry point.\n","def build_grpo_prompt(example: dict) -> str:\n","    question_with_hint = (\n","        example[\"question\"]\n","        + \"\\nPlease put your final answer inside `\\\\boxed{}`. \"\n","        + \"For example: `\\\\boxed{your answer}`\"\n","    )\n","    try:\n","        prompt = tokenizer.apply_chat_template(\n","            [{\"role\": \"user\", \"content\": question_with_hint}],\n","            tokenize=False,\n","            add_generation_prompt=True,\n","            enable_thinking=True,\n","        )\n","    except Exception:\n","        prompt = (\n","            \"<|im_start|>system\\ndetailed thinking on<|im_end|>\\n\"\n","            f\"<|im_start|>user\\n{question_with_hint}<|im_end|>\\n\"\n","            \"<|im_start|>assistant\\n\"\n","        )\n","    return prompt\n","\n","grpo_dataset = grpo_dataset.map(\n","    lambda x: {\"prompt\": build_grpo_prompt(x)},\n","    desc=\"Building DAPO prompts\",\n",")\n","\n","print(f\"[DAPO] Curriculum-ordered dataset ready: {len(grpo_dataset):,} samples\")\n","import collections\n","counts = collections.Counter(grpo_dataset[\"puzzle_type\"])\n","for k, v in sorted(counts.items()):\n","    print(f\"  {k}: {v}\")\n","gc.collect()"]},{"cell_type":"markdown","id":"2f7a2926","metadata":{"papermill":{"duration":0.005387,"end_time":"2026-05-02T12:12:21.208109+00:00","exception":false,"start_time":"2026-05-02T12:12:21.202722+00:00","status":"completed"},"tags":[]},"source":["## Step 2: Define the DAPO Reward Functions\n","\n","GRPO scores completions automatically using **reward functions**. We add a new **Verbosity Penalty** here (Flaw 4 Fix) to ensure the model finds the most mathematically efficient reasoning path rather than just rambling to farm gradients."]},{"cell_type":"code","execution_count":18,"id":"f79e655a","metadata":{"execution":{"iopub.execute_input":"2026-05-02T12:12:21.219713Z","iopub.status.busy":"2026-05-02T12:12:21.219587Z","iopub.status.idle":"2026-05-02T12:12:21.228525Z","shell.execute_reply":"2026-05-02T12:12:21.22825Z"},"papermill":{"duration":0.015462,"end_time":"2026-05-02T12:12:21.228981+00:00","exception":false,"start_time":"2026-05-02T12:12:21.213519+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["[BAPO] 5-Reward system armed:\n","  reward_format           — max 0.2\n","  reward_thinking_quality — max 0.1\n","  reward_correctness      — max 4.0  (exact only, no hacking partial credit)\n","  reward_numerical        — max 3.0  (float equiv, 1% tol, frac/LaTeX aware)\n","  reward_no_hacking       — penalty -0.5 for answer-in-think exploit\n","  ─────────────────────────\n","  Combined ceiling        : 7.3 pts\n"]}],"source":["import re\n","import math\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","# 5-REWARD SYSTEM\n","# Ceiling: reward_format(1.0) + reward_thinking_quality(0.5)\n","#        + reward_correctness(2.0) + reward_numerical(1.5)\n","#        + reward_no_hacking(0.5)  =  5.5 pts total\n","# ─────────────────────────────────────────────────────────────────────────────\n","\n","BOXED_PATTERN = re.compile(r\"\\\\boxed\\{([^{}]*(?:\\{[^{}]*\\}[^{}]*)*)\\}\")\n","\n","def _get_text(comp):\n","    return comp[0][\"content\"] if isinstance(comp, list) else comp\n","\n","def extract_boxed(text: str) -> str:\n","    \"\"\"Return the LAST \\\\boxed{} — avoids intermediate reasoning boxes.\"\"\"\n","    matches = BOXED_PATTERN.findall(text)\n","    return matches[-1].strip() if matches else \"\"\n","\n","def _norm(s: str) -> str:\n","    return re.sub(r\"\\s+\", \"\", s.strip()).lower()\n","\n","def _try_float(s: str):\n","    s = s.strip()\n","    s = re.sub(r\"\\\\text\\{[^}]*\\}\", \"\", s)\n","    s = re.sub(r\"\\\\,|\\\\;\", \"\", s)\n","    s = s.replace(\",\", \"\").replace(\"%\", \"\")\n","    frac = re.match(r\"\\\\frac\\{([^}]+)\\}\\{([^}]+)\\}\", s)\n","    if frac:\n","        try:\n","            return float(frac.group(1)) / float(frac.group(2))\n","        except Exception:\n","            pass\n","    try:\n","        return float(s)\n","    except Exception:\n","        return None\n","\n","# ── Reward 1: FORMAT ─────────────────────────────────────────────────────────\n","# <think> must open AND close. \\boxed{} must appear AFTER </think>.\n","def reward_format(completions, **kwargs) -> list:\n","    scores = []\n","    for comp in completions:\n","        text  = _get_text(comp)\n","        score = 0.0\n","        if \"<think>\" in text and \"</think>\" in text:\n","            score += 0.1\n","            tail = text.split(\"</think>\")[-1]\n","            if BOXED_PATTERN.search(tail):\n","                score += 0.1\n","        scores.append(score)\n","    return scores\n","\n","\n","# ── Reward 2: THINKING QUALITY ───────────────────────────────────────────────\n","# Prevents <think>ok</think>\\boxed{42} gaming of format reward.\n","# Requires ≥80 approximate tokens of real reasoning inside <think>.\n","def reward_thinking_quality(completions, **kwargs) -> list:\n","    scores = []\n","    for comp in completions:\n","        text  = _get_text(comp)\n","        score = 0.0\n","        if \"<think>\" in text and \"</think>\" in text:\n","            body          = text.split(\"<think>\")[-1].split(\"</think>\")[0].strip()\n","            approx_tokens = len(body) / 4\n","            if approx_tokens >= 80:\n","                score = 0.5\n","            elif approx_tokens >= 30:\n","                score = 0.25\n","        scores.append(score)\n","    return scores\n","\n","\n","# ── Reward 3: CORRECTNESS ─────────────────────────────────────────────────────\n","# Exact string / LaTeX match only — NO partial credit for answer appearing\n","# anywhere in text. That pattern trained reward hacking (answer in <think>).\n","def reward_correctness(completions, answer, **kwargs) -> list:\n","    scores = []\n","    for comp, gt in zip(completions, answer):\n","        text     = _get_text(comp)\n","        gt_clean = extract_boxed(gt) if BOXED_PATTERN.search(gt) else gt.strip()\n","        pred     = extract_boxed(text)\n","        scores.append(4.0 if (pred and _norm(pred) == _norm(gt_clean)) else -1.0)\n","    return scores\n","\n","\n","# ── Reward 4: NUMERICAL EQUIVALENCE ──────────────────────────────────────────\n","# Covers physics, unit conversion, algebra — any answer that parses as a float.\n","# Handles fractions, LaTeX fractions, percentages, scientific notation.\n","# 1% relative tolerance for full credit; 5% for partial.\n","def reward_numerical(completions, answer, **kwargs) -> list:\n","    scores = []\n","    for comp, gt in zip(completions, answer):\n","        text     = _get_text(comp)\n","        gt_clean = extract_boxed(gt) if BOXED_PATTERN.search(gt) else gt.strip()\n","        pred     = extract_boxed(text)\n","        if not pred:\n","            scores.append(0.0)\n","            continue\n","        gt_val, pred_val = _try_float(gt_clean), _try_float(pred)\n","        if gt_val is None or pred_val is None:\n","            scores.append(0.0)\n","            continue\n","        if math.isclose(gt_val, pred_val, rel_tol=0.01, abs_tol=1e-6):\n","            scores.append(3.0)\n","        elif math.isclose(gt_val, pred_val, rel_tol=0.05, abs_tol=1e-4):\n","            scores.append(1.0)\n","        else:\n","            scores.append(0.0)\n","    return scores\n","\n","\n","# ── Reward 5: ANTI-HACKING ────────────────────────────────────────────────────\n","# Detects and penalises the exploit: GT pasted inside <think> with wrong \\boxed{}.\n","# Penalty -0.5 (hacking detected)\n","def reward_no_hacking(completions, answer, **kwargs) -> list:\n","    scores = []\n","    for comp, gt in zip(completions, answer):\n","        text     = _get_text(comp)\n","        gt_clean = extract_boxed(gt) if BOXED_PATTERN.search(gt) else gt.strip()\n","        pred     = extract_boxed(text)\n","        score    = 0.0\n","        if \"<think>\" in text and \"</think>\" in text:\n","            think_body   = text.split(\"<think>\")[-1].split(\"</think>\")[0]\n","            gt_in_think  = _norm(gt_clean) in _norm(think_body)\n","            pred_correct = _norm(pred) == _norm(gt_clean)\n","            if gt_in_think and not pred_correct:\n","                score = -0.5\n","        scores.append(score)\n","    return scores\n","\n","# ── REWARD 6: SOFT OVERLONG PUNISHMENT (Paper Eq. 13) ────────────────────\n","# When response hits max_completion_length and is truncated,\n","# it receives a soft penalty proportional to truncation severity.\n","# Prevents reward noise from penalizing valid-but-long reasoning chains.\n","# Lcache = buffer zone before hard truncation where penalty ramps up.\n","\n","MAX_COMPLETION_LENGTH = 512   # Must match dapo_config.max_completion_length\n","LCACHE = 100                  # Penalty ramp-up window (last 100 tokens)\n","\n","def reward_overlong_shaping(completions, **kwargs) -> list:\n","    scores = []\n","    for comp in completions:\n","        text = _get_text(comp)\n","        # Approximate token count (~4 chars per token)\n","        approx_len = len(text) / 4\n","\n","        if approx_len <= (MAX_COMPLETION_LENGTH - LCACHE):\n","            # Response fits cleanly — no penalty\n","            scores.append(0.0)\n","        elif approx_len <= MAX_COMPLETION_LENGTH:\n","            # Inside the soft punishment zone — linear ramp\n","            penalty = ((MAX_COMPLETION_LENGTH - LCACHE) - approx_len) / LCACHE\n","            scores.append(penalty)   # Negative value\n","        else:\n","            # Hard truncation — maximum penalty\n","            scores.append(-1.0)\n","\n","    return scores\n","\n","print(\"[BAPO] 5-Reward system armed:\")\n","print(\"  reward_format           — max 0.2\")\n","print(\"  reward_thinking_quality — max 0.1\")\n","print(\"  reward_correctness      — max 4.0  (exact only, no hacking partial credit)\")\n","print(\"  reward_numerical        — max 3.0  (float equiv, 1% tol, frac/LaTeX aware)\")\n","print(\"  reward_no_hacking       — penalty -0.5 for answer-in-think exploit\")\n","print(\"  ─────────────────────────\")\n","print(\"  Combined ceiling        : 7.3 pts\")\n"]},{"cell_type":"markdown","id":"95b7e396","metadata":{"papermill":{"duration":0.005375,"end_time":"2026-05-02T12:12:21.239803+00:00","exception":false,"start_time":"2026-05-02T12:12:21.234428+00:00","status":"completed"},"tags":[]},"source":["## Step 3: Configure The Custom DAPO Trainer\n","\n","Here we subclass the Hugging Face `GRPOTrainer` to intercept the loss calculation. We inject the Asymmetric Clip-Higher logic and the Dynamic Sampling filter to brutally optimize our Kaggle compute window."]},{"cell_type":"code","execution_count":19,"id":"ef0997bd","metadata":{"execution":{"iopub.execute_input":"2026-05-02T12:12:21.251223Z","iopub.status.busy":"2026-05-02T12:12:21.251117Z","iopub.status.idle":"2026-05-02T12:12:29.089117Z","shell.execute_reply":"2026-05-02T12:12:29.088773Z"},"papermill":{"duration":7.844481,"end_time":"2026-05-02T12:12:29.089692+00:00","exception":false,"start_time":"2026-05-02T12:12:21.245211+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stderr","output_type":"stream","text":["warmup_ratio is deprecated and will be removed in v5.2. Use `warmup_steps` instead.\n"]},{"name":"stdout","output_type":"stream","text":["[DAPO] VRAM before training: 62.24 GB reserved\n","[DAPO] Trainer armed.\n","  Dataset          : 262 samples (curriculum-ordered)\n","  Group size G     : 4\n","  Temperature      : 0.9\n","  Max completion   : 768 tokens\n","  Max steps        : 250\n","  Grad accum       : 8 (effective BS=8)\n","  Learning rate    : 5e-07\n","  KL beta          : 0.0\n","  Clip ε_low/high  : 0.2 / 0.28\n","  Grad norm clip   : 0.3\n","\n","  Metrics to watch (every 5 steps):\n","    loss                    → non-zero, trending down from step 1\n","    reward_correctness      → trending from -1.0 toward +4.0\n","    reward_format           → trending toward 1.0\n","    reward_thinking_quality → trending toward 0.5\n","    reward_numerical        → trending toward 1.5\n","    reward_no_hacking       → holding near +0.5\n","    reward_overlong_shaping → staying near 0.0\n","    [BAPO] filtered %       → 20-40% healthy | 0% = fallback active\n","    [OOM] lines             → should be zero\n"]}],"source":["import torch\n","import torch.nn.functional as F\n","from trl import GRPOTrainer, GRPOConfig\n","import gc\n","import os\n","import time\n","from transformers import TrainerCallback\n","\n","# ── HARDWARE OPTIMIZATION FLAGS ───────────────────────────────────────────────\n","# TF32: ~15% free matmul speedup on A100. No precision loss for RL training.\n","torch.backends.cuda.matmul.allow_tf32 = True\n","torch.backends.cudnn.allow_tf32       = True\n","\n","# Expandable segments: prevents VRAM fragmentation on irregular 768-token allocs.\n","os.environ[\"PYTORCH_CUDA_ALLOC_CONF\"] = \"expandable_segments:True\"\n","\n","# ── PRE-TRAINING VRAM PURGE ───────────────────────────────────────────────────\n","gc.collect()\n","torch.cuda.empty_cache()\n","print(f\"[DAPO] VRAM before training: {torch.cuda.memory_reserved()/1024**3:.2f} GB reserved\")\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","# DAPOTrainer — Full paper-aligned implementation (arXiv:2503.14476)\n","#\n","# Technique 1: Clip-Higher        — asymmetric ε_low/ε_high at ratio level\n","# Technique 2: Dynamic Sampling   — group-level zero-variance filter + fallback\n","# Technique 3: Token-Level Loss   — divide by total tokens (Paper Eq. 12)\n","# Technique 4: KL = 0             — paper Section 2.3, removed for long-CoT\n","#\n","# Robustness additions:\n","#   - use_cache toggle: re-enabled during generation, disabled during training\n","#   - Advantage normalization + hard clamp [-5, 5]\n","#   - Ratio safety hard clip [0.01, 20.0]\n","#   - OOM recovery guard on forward pass\n","# ─────────────────────────────────────────────────────────────────────────────\n","class DAPOTrainer(GRPOTrainer):\n","\n","    def __init__(self, *args, eps_low: float = 0.2, eps_high: float = 0.28, **kwargs):\n","        super().__init__(*args, **kwargs)\n","        self.eps_low        = eps_low\n","        self.eps_high       = eps_high\n","        self._stats         = {\"active\": 0, \"filtered\": 0}\n","        self.global_baseline = 1.0\n","\n","    @staticmethod\n","    def _token_logps(logits: torch.Tensor, input_ids: torch.Tensor) -> torch.Tensor:\n","        \"\"\"Per-token log-probs aligned to input_ids[:, 1:].\"\"\"\n","        lp = F.log_softmax(logits[:, :-1].float(), dim=-1)\n","        return lp.gather(-1, input_ids[:, 1:].unsqueeze(-1)).squeeze(-1)\n","\n","    def _generate_completions(self, *args, **kwargs):\n","        \"\"\"\n","        UPGRADE 1: Re-enable KV cache during rollout generation only.\n","        model.config.use_cache was globally disabled by the NemotronH\n","        gradient checkpointing bypass. That is correct for training forward\n","        passes but kills generation speed 3-4x. Toggle it here.\n","        \"\"\"\n","        self.model.config.use_cache = True\n","        result = super()._generate_completions(*args, **kwargs)\n","        self.model.config.use_cache = False   # Restore for training\n","        return result\n","\n","    def compute_loss(self, model, inputs, return_outputs=False, **extra):\n","\n","        # ── Guard: fall back to parent if expected keys missing ───────────────\n","        if \"advantages\" not in inputs:\n","            return super().compute_loss(model, inputs, return_outputs, **extra)\n","\n","        advantages = inputs[\"advantages\"]\n","\n","        # ── Input extraction (TRL version compatibility) ──────────────────────\n","        if \"input_ids\" in inputs:\n","            input_ids      = inputs[\"input_ids\"]\n","            attention_mask = inputs[\"attention_mask\"]\n","        else:\n","            prompt_ids      = inputs[\"prompt_ids\"]\n","            prompt_mask     = inputs[\"prompt_mask\"]\n","            completion_ids  = inputs[\"completion_ids\"]\n","            completion_mask = inputs[\"completion_mask\"]\n","            input_ids       = torch.cat([prompt_ids, completion_ids], dim=1)\n","            attention_mask  = torch.cat([prompt_mask, completion_mask], dim=1)\n","            inputs[\"completion_mask\"] = completion_mask\n","\n","        comp_mask = inputs.get(\"completion_mask\", attention_mask)\n","        old_logps = inputs.get(\"old_per_token_logps\")\n","        ref_logps = inputs.get(\"ref_per_token_logps\")\n","\n","        G = self.args.num_generations\n","        N = advantages.shape[0]\n","\n","        # ── Advantage computation ─────────────────────────────────────────────\n","        if \"rewards\" in inputs:\n","            rewards          = inputs[\"rewards\"]\n","            current_mean     = rewards.mean().item()\n","            self.global_baseline = 0.9 * self.global_baseline + 0.1 * current_mean\n","            advantages       = rewards - self.global_baseline\n","        else:\n","            advantages       = inputs[\"advantages\"]\n","\n","        # ── DYNAMIC SAMPLING — group-level filter (Paper Section 3.2) ─────────\n","        # Groups where all G completions are correct OR all wrong → advantage\n","        # std ≈ 0 → zero gradient → wasted compute. Filter them out.\n","        # FALLBACK: early training often has 100% wrong on every group.\n","        # In that case train on everything rather than returning zero loss.\n","        if N >= G and N % G == 0:\n","            adv_grouped      = advantages.view(-1, G)\n","            group_has_signal = adv_grouped.std(dim=1) > 1e-6\n","            active_n         = group_has_signal.repeat_interleave(G)\n","        else:\n","            active_n = torch.ones_like(advantages, dtype=torch.bool)\n","\n","        n_active_samples = int(active_n.sum().item())\n","\n","        # BUG FIX: compute n_filtered BEFORE fallback modifies active_n.\n","        # Previous version recalculated after fallback, overwriting n_filtered=0.\n","        if n_active_samples == 0:\n","            active_n           = torch.ones_like(advantages, dtype=torch.bool)\n","            n_active_samples   = N\n","            n_filtered_samples = 0\n","        else:\n","            n_filtered_samples = N - n_active_samples\n","\n","        self._stats[\"active\"]   += n_active_samples\n","        self._stats[\"filtered\"] += n_filtered_samples\n","\n","        # ── Filter tensors to active samples only ─────────────────────────────\n","        def _filt(t):\n","            return t[active_n] if t is not None else None\n","\n","        adv_f = _filt(advantages)\n","        ids_f = _filt(input_ids)\n","        msk_f = _filt(attention_mask)\n","        cmp_f = _filt(comp_mask)\n","        old_f = _filt(old_logps)\n","        ref_f = _filt(ref_logps)\n","\n","        # ── Forward pass with OOM recovery guard ──────────────────────────────\n","        try:\n","            outputs   = model(input_ids=ids_f, attention_mask=msk_f)\n","            new_logps = self._token_logps(outputs.logits, ids_f)\n","        except torch.cuda.OutOfMemoryError:\n","            gc.collect()\n","            torch.cuda.empty_cache()\n","            print(f\"[OOM] Step recovered. VRAM: {torch.cuda.memory_reserved()/1024**3:.1f} GB\")\n","            dummy = sum(p.sum() * 0 for p in model.parameters() if p.requires_grad)\n","            return dummy\n","\n","        # ── Align sequence lengths ────────────────────────────────────────────\n","        tok_mask  = cmp_f[:, 1:].float()\n","        min_len   = min(tok_mask.shape[1], new_logps.shape[1])\n","        tok_mask  = tok_mask[:, :min_len]\n","        new_logps = new_logps[:, :min_len]\n","\n","        # ── Policy ratio ──────────────────────────────────────────────────────\n","        if old_f is not None:\n","            old_al = old_f[:, :min_len]\n","            ratio  = torch.exp(new_logps - old_al)\n","        else:\n","            # No old logps — ratio = 1 everywhere, keep in graph\n","            ratio = torch.exp(new_logps - new_logps.detach())\n","\n","        # ── ADVANTAGE NORMALIZATION ───────────────────────────────────────────\n","        # Normalize per-batch: mean=0, std=1. Bounds reward scale.\n","        if adv_f.numel() > 1:\n","            adv_f = (adv_f - adv_f.mean()) / (adv_f.std() + 1e-8)\n","\n","        # ── ADVANTAGE HARD CLAMP ──────────────────────────────────────────────\n","        # Clips normalized advantages to [-5, 5].\n","        # Prevents single outlier reward dominating gradient post-normalization.\n","        adv_f = torch.clamp(adv_f, -5.0, 5.0)\n","\n","        # ── RATIO SAFETY HARD CLIP ────────────────────────────────────────────\n","        # Numerical guard separate from DAPO clip. Prevents exp() explosion\n","        # when old_logps diverges from current policy on hard prompts.\n","        ratio = torch.clamp(ratio, 0.01, 20.0)\n","\n","        # ── CLIP-HIGHER (Paper Section 3.1) ───────────────────────────────────\n","        # Asymmetric clip: ε_low for downward, ε_high for upward.\n","        # Preserves exploration of low-probability tokens.\n","        ratio_clipped = torch.clamp(ratio, 1.0 - self.eps_low, 1.0 + self.eps_high)\n","\n","        adv_tok  = adv_f.unsqueeze(-1).expand_as(ratio)\n","        surr1    = ratio         * adv_tok\n","        surr2    = ratio_clipped * adv_tok\n","        tok_loss = -torch.min(surr1, surr2)\n","\n","        # ── TRUE TOKEN-LEVEL LOSS (Paper Eq. 12) ──────────────────────────────\n","        # Divide by TOTAL active tokens across all sequences in batch.\n","        # BUG FIX from previous version: per-seq mean then batch mean\n","        # is still sample-level loss, not token-level. This is the fix.\n","        total_tokens = tok_mask.sum().clamp(min=1.0)\n","        policy_loss  = (tok_loss * tok_mask).sum() / total_tokens\n","\n","        # ── KL penalty (beta=0.0 per Paper Section 2.3) ───────────────────────\n","        # KL removed for long-CoT RL. Guard kept for future experimentation.\n","        # BUG FIX: previous version referenced seq_lengths which no longer\n","        # exists after token-level loss rewrite — now uses total_tokens.\n","        kl_loss = policy_loss.new_zeros(())\n","        beta    = getattr(self.args, \"beta\", 0.0)\n","        if beta > 0 and ref_f is not None:\n","            ref_al  = ref_f[:, :min_len]\n","            kl_tok  = torch.exp(ref_al - new_logps) - (ref_al - new_logps) - 1.0\n","            kl_loss = beta * (kl_tok * tok_mask).sum() / total_tokens\n","\n","        loss = policy_loss + kl_loss\n","\n","        # ── Step logging ───────────────────────────────────────────────────────\n","        total = self._stats[\"active\"] + self._stats[\"filtered\"]\n","        if total > 0 and total % (G * 5) == 0:\n","            filt_pct     = 100 * self._stats[\"filtered\"] / max(total, 1)\n","            current_step = getattr(self.state, \"global_step\", 0)\n","            max_steps    = getattr(self.args, \"max_steps\", 1)\n","            progress_pct = 100 * current_step / max(max_steps, 1)\n","            print(\n","                f\"[BAPO | {progress_pct:.1f}%] \"\n","                f\"Step={current_step}/{max_steps} | \"\n","                f\"active={self._stats['active']} | \"\n","                f\"filtered={self._stats['filtered']} ({filt_pct:.0f}%) | \"\n","                f\"ε=[{self.eps_low},{self.eps_high}] | \"\n","                f\"loss={loss.item():.4f}\"\n","            )\n","\n","        return loss\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","class KaggleTimeLimitCallback(TrainerCallback):\n","    \"\"\"\n","    Measures from TRAINING STEP 1, not notebook start.\n","    psutil.Process().create_time() was burning the budget during model\n","    load and wheel install before DAPO even started.\n","    \"\"\"\n","    def __init__(self, max_hours=4.5):\n","        self.max_seconds         = max_hours * 3600\n","        self.training_start_time = None\n","\n","    def on_step_begin(self, args, state, control, **kwargs):\n","        if self.training_start_time is None:\n","            self.training_start_time = time.time()\n","            print(f\"[TIMER] Training clock started at step 1. Budget: {self.max_seconds/3600:.1f}h\")\n","\n","    def on_step_end(self, args, state, control, **kwargs):\n","        if self.training_start_time is None:\n","            return\n","        elapsed = time.time() - self.training_start_time\n","        if elapsed >= self.max_seconds:\n","            print(f\"\\n[SAFETY] {elapsed/3600:.2f}h training elapsed. Stopping and saving.\")\n","            control.should_training_stop = True\n","\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","dapo_config = GRPOConfig(\n","    output_dir                  = \"/kaggle/working/nemotron_bapo_adapter\",\n","    max_completion_length       = 768,\n","    # max_prompt_length REMOVED from here\n","    num_generations             = 4,\n","    temperature                 = 0.9,\n","    top_p                       = 0.95,\n","    per_device_train_batch_size = 1,\n","    gradient_accumulation_steps = 8,\n","    gradient_checkpointing      = False,\n","    optim                       = \"paged_adamw_8bit\",\n","    learning_rate               = 5e-7,\n","    max_steps                   = 250,\n","    warmup_ratio                = 0.10,\n","    lr_scheduler_type           = \"cosine\",\n","    weight_decay                = 0.01,\n","    max_grad_norm               = 0.3,\n","    beta                        = 0.0,\n","    bf16                        = True,\n","    fp16                        = False,\n","    dataloader_pin_memory       = True,\n","    dataloader_num_workers      = 2,\n","    logging_steps               = 5,\n","    save_strategy               = \"steps\",\n","    save_steps                  = 50,\n","    report_to                   = \"none\",\n","    seed                        = 3407,\n","    remove_unused_columns       = False,\n",")\n","\n","dapo_trainer = DAPOTrainer(\n","    model            = model,\n","    args             = dapo_config,\n","    train_dataset    = grpo_dataset,\n","    reward_funcs     = [\n","        reward_format,\n","        reward_thinking_quality,\n","        reward_correctness,\n","        reward_numerical,\n","        reward_no_hacking,\n","        reward_overlong_shaping,\n","    ],\n","    processing_class = tokenizer,\n","    # max_prompt_length = 256,        # ← MOVED HERE\n","    eps_low          = 0.2,\n","    eps_high         = 0.28,\n","    callbacks        = [KaggleTimeLimitCallback(max_hours=4.5)],\n",")\n","\n","print(\"[DAPO] Trainer armed.\")\n","print(f\"  Dataset          : {len(grpo_dataset):,} samples (curriculum-ordered)\")\n","print(f\"  Group size G     : {dapo_config.num_generations}\")\n","print(f\"  Temperature      : {dapo_config.temperature}\")\n","print(f\"  Max completion   : {dapo_config.max_completion_length} tokens\")\n","# print(f\"  Max prompt       : {dapo_config.max_prompt_length} tokens\")...,/...\n","print(f\"  Max steps        : {dapo_config.max_steps}\")\n","print(f\"  Grad accum       : {dapo_config.gradient_accumulation_steps} (effective BS={dapo_config.gradient_accumulation_steps * dapo_config.per_device_train_batch_size})\")\n","print(f\"  Learning rate    : {dapo_config.learning_rate}\")\n","print(f\"  KL beta          : {dapo_config.beta}\")\n","print(f\"  Clip ε_low/high  : {dapo_trainer.eps_low} / {dapo_trainer.eps_high}\")\n","print(f\"  Grad norm clip   : {dapo_config.max_grad_norm}\")\n","print()\n","print(\"  Metrics to watch (every 5 steps):\")\n","print(\"    loss                    → non-zero, trending down from step 1\")\n","print(\"    reward_correctness      → trending from -1.0 toward +4.0\")\n","print(\"    reward_format           → trending toward 1.0\")\n","print(\"    reward_thinking_quality → trending toward 0.5\")\n","print(\"    reward_numerical        → trending toward 1.5\")\n","print(\"    reward_no_hacking       → holding near +0.5\")\n","print(\"    reward_overlong_shaping → staying near 0.0\")\n","print(\"    [BAPO] filtered %       → 20-40% healthy | 0% = fallback active\")\n","print(\"    [OOM] lines             → should be zero\")"]},{"cell_type":"markdown","id":"90a28c5f","metadata":{"papermill":{"duration":0.00543,"end_time":"2026-05-02T12:12:29.101038+00:00","exception":false,"start_time":"2026-05-02T12:12:29.095608+00:00","status":"completed"},"tags":[]},"source":["## Step 4: VRAM Safety Check Before GRPO Training\n","\n","GRPO is more VRAM-hungry than SFT because it holds **G=4 completions** in memory\n","simultaneously during the rollout phase. We check free VRAM before launching and\n","abort with an actionable error if headroom is insufficient."]},{"cell_type":"code","execution_count":20,"id":"5fd26e23","metadata":{"execution":{"iopub.execute_input":"2026-05-02T12:12:29.11269Z","iopub.status.busy":"2026-05-02T12:12:29.112578Z","iopub.status.idle":"2026-05-02T12:12:29.776764Z","shell.execute_reply":"2026-05-02T12:12:29.776477Z"},"papermill":{"duration":0.670869,"end_time":"2026-05-02T12:12:29.777372+00:00","exce