r.shared_experts.up_proj.lora_A.default.weight', 'base_model.model.backbone.layers.51.mixer.shared_experts.up_proj.lora_B.default.weight', 'base_model.model.backbone.layers.51.mixer.shared_experts.down_proj.lora_A.default.weight', 'base_model.model.backbone.layers.51.mixer.shared_experts.down_proj.lora_B.default.weight'].\n","  warnings.warn(warn_message)\n"]},{"name":"stdout","output_type":"stream","text":["[DAPO] Adapter loaded. Trainable params: 888,154,112\n","[DAPO] Gradient checkpointing force-applied (manual bypass).\n","\n","[DAPO] Full dataset: 262 samples\n","  bit_manipulation    :   34  (13.0%)\n","  encryption          :   30  (11.5%)\n","  gravity             :   86  (32.8%)\n","  roman_numeral       :   12  (4.6%)\n","  transformation      :   69  (26.3%)\n","  unit_conversion     :   31  (11.8%)\n","\n","[DAPO] Sequential run plan (4 runs):\n","  Run 'warmup':  262 samples | LR=8e-06 | steps=30 | WARM-UP: all categories, high LR, learn the format\n","  Run 'numerical':  117 samples | LR=5e-06 | steps=60 | Physics + unit conversion (numerical reasoning)\n","  Run 'cipher':   99 samples | LR=3e-06 | steps=60 | Pattern transforms + cipher decryption\n","  Run 'symbolic':   46 samples | LR=3e-06 | steps=40 | Bit ops + roman numerals + misc\n","\n","[DAPO] Total training steps: 190\n"]},{"data":{"text/plain":["62"]},"execution_count":17,"metadata":{},"output_type":"execute_result"}],"source":["import gc\n","import torch\n","import os\n","import re\n","import pandas as pd\n","from datasets import load_dataset, Dataset\n","from peft import PeftModel, LoraConfig, get_peft_model\n","from transformers import AutoModelForCausalLM, AutoTokenizer\n","import datasets\n","import collections\n","\n","datasets.utils.logging.disable_progress_bar()\n","\n","BASE_MODEL_PATH = \"/kaggle/input/models/metric/nemotron-3-nano-30b-a3b-bf16/transformers/default/1\"\n","ADAPTER_3_PATH = \"/kaggle/input/datasets/banwait13/lora-adapter/NEMOTRON/1\"\n","\n","if 'model' not in globals() or model is None:\n","    print(\"[DAPO] Loading Base Model...\")\n","    model = AutoModelForCausalLM.from_pretrained(\n","        BASE_MODEL_PATH,\n","        device_map=\"auto\",\n","        torch_dtype=torch.bfloat16,\n","        trust_remote_code=True,\n","    )\n","    tokenizer = AutoTokenizer.from_pretrained(BASE_MODEL_PATH, trust_remote_code=True)\n","    if tokenizer.unk_token is not None:\n","        tokenizer.pad_token = tokenizer.unk_token\n","    else:\n","        tokenizer.pad_token = tokenizer.eos_token\n","    tokenizer.padding_side = \"right\"\n","\n","    print(\"[DAPO] Attaching Adapter 3 as trainable...\")\n","    model = PeftModel.from_pretrained(model, ADAPTER_3_PATH, is_trainable=True)\n","    print(f\"[DAPO] Adapter loaded. Trainable params: {sum(p.numel() for p in model.parameters() if p.requires_grad):,}\")\n","else:\n","    print(\"[DAPO] Model already in memory.\")\n","\n","# ── NUCLEAR FIX: Manually apply gradient checkpointing ────────────────────\n","# NemotronHForCausalLM does not declare gradient checkpointing support,\n","# so gradient_checkpointing_enable() throws a ValueError.\n","# We bypass the method entirely and do what it does internally.\n","import functools as _ft\n","from torch.utils.checkpoint import checkpoint as _torch_ckpt\n","\n","model.config.use_cache = False\n","_gc_fn = _ft.partial(_torch_ckpt, use_reentrant=False)\n","for _m in model.modules():\n","    if hasattr(_m, 'gradient_checkpointing'):\n","        _m.gradient_checkpointing = True\n","    _m._gradient_checkpointing_func = _gc_fn\n","\n","if hasattr(model, \"enable_input_require_grads\"):\n","    model.enable_input_require_grads()\n","\n","print(\"[DAPO] Gradient checkpointing force-applied (manual bypass).\")\n","\n","# ── Load FULL dataset (1000 samples) ─────────────────────────────────────────\n","_raw_dataset = load_dataset(\n","    \"csv\",\n","    data_files=\"/kaggle/input/datasets/banwait13/lora-adapter/DATASETS/GRPO_TEST.csv\",\n","    split=\"train\",\n",")\n","\n","def normalize_cols(sample):\n","    question = (\n","        sample.get(\"instruction\") or sample.get(\"prompt\")\n","        or sample.get(\"question\") or \"\"\n","    )\n","    answer = (\n","        sample.get(\"response\") or sample.get(\"answer\")\n","        or sample.get(\"output\") or \"\"\n","    )\n","    return {\n","        \"question\":    str(question).strip(),\n","        \"answer\":      str(answer).strip(),\n","    }\n","\n","_raw_dataset = _raw_dataset.map(normalize_cols, num_proc=2)\n","\n","# ── Auto-categorize puzzles from instruction text ─────────────────────────────\n","def _categorize_instruction(text: str) -> str:\n","    t = str(text).lower()\n","    if \"gravitational\" in t or \"falling distance\" in t or \"d = 0.5*g*t\" in t:\n","        return \"gravity\"\n","    elif \"bit manipulation\" in t or \"binary\" in t:\n","        return \"bit_manipulation\"\n","    elif \"decrypt\" in t or \"encrypt\" in t or \"cipher\" in t:\n","        return \"encryption\"\n","    elif \"unit conversion\" in t or \"convert the following measurement\" in t:\n","        return \"unit_conversion\"\n","    elif \"numeral\" in t or \"roman\" in t:\n","        return \"roman_numeral\"\n","    elif \"transformation rules\" in t or \"transformation\" in t:\n","        return \"transformation\"\n","    else:\n","        return \"other\"\n","\n","_raw_dataset = _raw_dataset.map(\n","    lambda x: {\"puzzle_type\": _categorize_instruction(x[\"question\"])},\n","    desc=\"Categorizing puzzles\",\n",")\n","\n","# ── Build prompts ─────────────────────────────────────────────────────────────\n","def build_grpo_prompt(example: dict) -> str:\n","    question_with_hint = (\n","        example[\"question\"]\n","        + \"\\nThink step by step inside <think> tags, then give your final answer inside \\\\boxed{}.\"\n","        + \"\\nFormat required: <think>your reasoning</think> \\\\boxed{your answer}\"\n","    )\n","    try:\n","        prompt = tokenizer.apply_chat_template(\n","            [{\"role\": \"user\", \"content\": question_with_hint}],\n","            tokenize=False,\n","            add_generation_prompt=True,\n","            enable_thinking=True,\n","        )\n","    except Exception:\n","        prompt = (\n","            \"<|im_start|>system\\ndetailed thinking on<|im_end|>\\n\"\n","            f\"<|im_start|>user\\n{question_with_hint}<|im_end|>\\n\"\n","            \"<|im_start|>assistant\\n<think>\\n\"   # ← force open the think block\n","        )\n","    return prompt\n","\n","_raw_dataset = _raw_dataset.map(\n","    lambda x: {\"prompt\": build_grpo_prompt(x)},\n","    desc=\"Building DAPO prompts\",\n",")\n","\n","# ── Per-category dataset splits for sequential DAPO runs ──────────────────────\n","# Strategy: 3 sequential runs on the SAME adapter, each specializing in\n","# a cluster of related problem types. This prevents the model from having\n","# to context-switch between completely unrelated reasoning strategies.\n","#\n","# Run ordering: easiest → hardest (so the adapter warms up on solvable problems)\n","\n","BAPO_RUNS = [\n","    {\n","        \"name\": \"warmup\",\n","        \"cats\": [\"gravity\", \"unit_conversion\", \"roman_numeral\",\n","                 \"transformation\", \"encryption\", \"bit_manipulation\", \"other\"],\n","        \"description\": \"WARM-UP: all categories, high LR, learn the format\",\n","        \"lr\": 8e-6,\n","        \"max_steps\": 30,\n","    },\n","    {\n","        \"name\": \"numerical\",\n","        \"cats\": [\"gravity\", \"unit_conversion\"],\n","        \"description\": \"Physics + unit conversion (numerical reasoning)\",\n","        \"lr\": 5e-6,\n","        \"max_steps\": 60,\n","    },\n","    {\n","        \"name\": \"cipher\",\n","        \"cats\": [\"transformation\", \"encryption\"],\n","        \"description\": \"Pattern transforms + cipher decryption\",\n","        \"lr\": 3e-6,\n","        \"max_steps\": 60,\n","    },\n","    {\n","        \"name\": \"symbolic\",\n","        \"cats\": [\"bit_manipulation\", \"roman_numeral\", \"other\"],\n","        \"description\": \"Bit ops + roman numerals + misc\",\n","        \"lr\": 3e-6,\n","        \"max_steps\": 40,\n","    },\n","]\n","\n","\n","# Build category subsets (shuffle within each, but keep category grouping)\n","bapo_run_datasets = {}\n","for run_cfg in BAPO_RUNS:\n","    subset = _raw_dataset.filter(\n","        lambda x, cats=run_cfg[\"cats\"]: x[\"puzzle_type\"] in cats,\n","        desc=f\"Filtering {run_cfg['name']}\",\n","    )\n","    # Shuffle within the subset\n","    subset = subset.shuffle(seed=3407)\n","    bapo_run_datasets[run_cfg[\"name\"]] = subset\n","\n","# Clean up columns: keep only what BAPOTrainer needs\n","keep = {\"question\", \"answer\", \"puzzle_type\", \"prompt\"}\n","for name in bapo_run_datasets:\n","    ds = bapo_run_datasets[name]\n","    drop = [c for c in ds.column_names if c not in keep]\n","    if drop:\n","        bapo_run_datasets[name] = ds.remove_columns(drop)\n","\n","# Also keep a combined dataset as fallback\n","grpo_dataset = _raw_dataset.shuffle(seed=3407)\n","drop = [c for c in grpo_dataset.column_names if c not in keep]\n","if drop:\n","    grpo_dataset = grpo_dataset.remove_columns(drop)\n","\n","# ── Report ────────────────────────────────────────────────────────────────────\n","print(f\"\\n[DAPO] Full dataset: {len(_raw_dataset):,} samples\")\n","counts = collections.Counter(_raw_dataset[\"puzzle_type\"])\n","for k, v in sorted(counts.items()):\n","    print(f\"  {k:20s}: {v:4d}  ({100*v/len(_raw_dataset):.1f}%)\")\n","\n","print(f\"\\n[DAPO] Sequential run plan ({len(BAPO_RUNS)} runs):\")\n","for run_cfg in BAPO_RUNS:\n","    ds = bapo_run_datasets[run_cfg[\"name\"]]\n","    print(f\"  Run '{run_cfg['name']}': {len(ds):4d} samples | LR={run_cfg['lr']:.0e} | steps={run_cfg['max_steps']} | {run_cfg['description']}\")\n","\n","print(f\"\\n[DAPO] Total training steps: {sum(r['max_steps'] for r in BAPO_RUNS)}\")\n","gc.collect()"]},{"cell_type":"markdown","id":"44af4598","metadata":{"papermill":{"duration":0.008394,"end_time":"2026-05-17T12:15:01.145798+00:00","exception":false,"start_time":"2026-05-17T12:15:01.137404+00:00","status":"completed"},"tags":[]},"source":["## Step 2: Define the BAPO Reward Functions\n","\n","BAPO scores completions automatically using **reward functions**. We add a new **Verbosity Penalty** here (Flaw 4 Fix) to ensure the model finds the most mathematically efficient reasoning path rather than just rambling to farm gradients."]},{"cell_type":"code","execution_count":18,"id":"644a6917","metadata":{"execution":{"iopub.execute_input":"2026-05-17T12:15:01.163676Z","iopub.status.busy":"2026-05-17T12:15:01.163546Z","iopub.status.idle":"2026-05-17T12:15:01.173111Z","shell.execute_reply":"2026-05-17T12:15:01.172847Z"},"papermill":{"duration":0.019261,"end_time":"2026-05-17T12:15:01.173598+00:00","exception":false,"start_time":"2026-05-17T12:15:01.154337+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["[BAPO] 6-Reward system armed:\n","  reward_format           — max 1.0  (0.5 think + 0.5 boxed)\n","  reward_thinking_quality — max 0.5\n","  reward_correctness      — +4.0 correct | 0.0 no boxed | -1.0 wrong\n","  reward_numerical        — max 3.0  (float equiv, 1% tol, frac/LaTeX aware)\n","  reward_no_hacking       — penalty -0.5 for answer-in-think exploit\n","  reward_overlong_shaping — 0.0 to -1.0 soft truncation penalty\n","  ─────────────────────────\n","  Combined ceiling        : 8.5 pts (1.0+0.5+4.0+3.0+0.0+0.0)\n"]}],"source":["import re\n","import math\n","\n","# ─────────────────────────────────────────────────────────────────────────────\n","# 5-REWARD SYSTEM\n","# Ceiling: reward_format(1.0) + reward_thinking_quality(0.5)\n","#        + reward_correctness(2.0) + reward_numerical(1.5)\n","#        + reward_no_hacking(0.5)  =  5.5 pts total\n","# ─────────────────────────────────────────────────────────────────────────────\n","\n","BOXED_PATTERN = re.compile(r\"\\\\boxed\\{([^{}]*(?:\\{[^{}]*\\}[^{}]*)*)\\}\")\n","\n","def _get_text(comp):\n","    return comp[0][\"content\"] if isinstance(comp, list) else comp\n","\n","def extract_boxed(text: str) -> str:\n","    \"\"\"Return the LAST \\\\boxed{} — avoids intermediate reasoning boxes.\"\"\"\n","    matches = BOXED_PATTERN.findall(text)\n","    return matches[-1].strip() if matches else \"\"\n","\n","def _norm(s: str) -> str:\n","    return re.sub(r\"\\s+\", \"\", s.strip()).lower()\n","\n","def _try_float(s: str):\n","    s = s.strip()\n","    s = re.sub(r\"\\\\text\\{[^}]*\\}\", \"\", s)\n","    s = re.sub(r\"\\\\,|\\\\;\", \"\", s)\n","    s = s.replace(\",\", \"\").replace(\"%\", \"\")\n","    frac = re.match(r\"\\\\frac\\{([^}]+)\\}\\{([^}]+)\\}\", s)\n","    if frac:\n","        try:\n","            return float(frac.group(1)) / float(frac.group(2))\n","        except Exception:\n","            pass\n","    try:\n","        return float(s)\n","    except Exception:\n","        return None\n","\n","# ── Reward 1: FORMAT ─────────────────────────────────────────────────────────\n","# The prompt already ends with <think>\\n, so the COMPLETION won't contain\n","# \"<think>\" — only \"</think>\" and \"\\boxed{}\". We reward:\n","#   +0.5 for having </think>  (closed the thinking block)\n","#   +0.5 for having \\boxed{} AFTER the last </think>\n","# This matches what the model actually produces given the prompt structure.\n","def reward_format(completions, **kwargs) -> list:\n","    scores = []\n","    for comp in completions:\n","        text  = _get_text(comp)\n","        score = 0.0\n","        # Accept either: completion has both <think>+</think>, OR just </think>\n","        # (because <think> is already in the prompt prefix)\n","        has_close = \"</think>\" in text\n","        if has_close:\n","            score += 0.5\n","            tail = text.split(\"</think>\")[-1]\n","            if BOXED_PATTERN.search(tail):\n","                score += 0.5\n","        scores.append(score)\n","    return scores\n","\n","\n","# ── Reward 2: THINKING QUALITY ───────────────────────────────────────────────\n","# Prevents </think>\\boxed{42} gaming of format reward.\n","# Requires ≥80 approximate tokens of real reasoning before </think>.\n","# Note: <think> may be in the prompt, so we only look for </think> in completion.\n","def reward_thinking_quality(completions, **kwargs) -> list:\n","    scores = []\n","    for comp in completions:\n","        text  = _get_text(comp)\n","        score = 0.0\n","        if \"</think>\" in text:\n","            # Everything before the FIRST </think> is the think body\n","            # (whether or not <think> appears in the completion)\n","            if \"<think>\" in text:\n","                body = text.split(\"<think>\")[-1].split(\"</think>\")[0].strip()\n","            else:\n","                body = text.split(\"</think>\")[0].strip()\n","            approx_tokens = len(body) / 4\n","            if approx_tokens >= 80:\n","                score = 0.5\n","            elif approx_tokens >= 30:\n","                score = 0.25\n","        scores.append(score)\n","    return scores\n","\n","\n","# ── Reward 3: CORRECTNESS ─────────────────────────────────────────────────────\n","# 3-tier: correct → +4.0, wrong answer in \\boxed{} → -1.0, no \\boxed{} → 0.0\n","# The 0.0 neutral tier prevents punishing the model for not knowing the format\n","# yet — let reward_format handle format compliance separately.\n","def reward_correctness(completions, answer, **kwargs) -> list:\n","    scores = []\n","    for comp, gt in zip(completions, answer):\n","        text     = _get_text(comp)\n","        gt_clean = extract_boxed(gt) if BOXED_PATTERN.search(gt) else gt.strip()\n","        pred     = extract_boxed(text)\n","        if not pred:\n","            scores.append(0.0)    # No \\boxed{} at all — neutral, don't punish\n","        elif _norm(pred) == _norm(gt_clean):\n","            scores.append(4.0)    # Correct answer\n","        else:\n","            scores.append(-1.0)   # Wrong answer in \\boxed{}\n","    return scores\n","\n","\n","# ── Reward 4: NUMERICAL EQUIVALENCE ──────────────────────────────────────────\n","# Covers physics, unit conversion, algebra — any answer that parses as a float.\n","# Handles fractions, LaTeX fractions, percentages, scientific notation.\n","# 1% relative tolerance for full credit; 5% for partial.\n","def reward_numerical(completions, answer, **kwargs) -> list:\n","    scores = []\n","    for comp, gt in zip(completions, answer):\n","        text     = _get_text(comp)\n","        gt_clean = extract_boxed(gt) if BOXED_PATTERN.search(gt) else gt.strip()\n","        pred     = extract_boxed(text)\n","        if not pred:\n","            scores.append(0.0)\n","            continue\n","        gt_val, pred_val = _try_float(gt_clean), _try_float(pred)\n","        if gt_val is None or pred_val is None:\n","            scores.append(0.0)\n","            continue\n","        if math.isclose(gt_val, pred_val, rel_tol=0.01, abs_tol=1e-6):\n","            scores.append(3.0)\n","        elif math.isclose(gt_val, pred_val, rel_tol=0.05, abs_tol=1e-4):\n","            scores.append(1.0)\n","        else:\n","            scores.append(0.0)\n","    return scores\n","\n","\n","# ── Reward 5: ANTI-HACKING ────────────────────────────────────────────────────\n","# Detects and penalises the exploit: GT pasted inside think block with wrong \\boxed{}.\n","# Note: <think> may be in the prompt, so we accept </think> alone.\n","def reward_no_hacking(completions, answer, **kwargs) -> list:\n","    scores = []\n","    for comp, gt in zip(completions, answer):\n","        text     = _get_text(comp)\n","        gt_clean = extract_boxed(gt) if BOXED_PATTERN.search(gt) else gt.strip()\n","        pred     = extract_boxed(text)\n","        score    = 0.0\n","        if \"</think>\" in text:\n","            # Extract think body — handle both cases\n","            if \"<think>\" in text:\n","                think_body = text.split(\"<think>\")[-1].split(\"</think>\")[0]\n","            else:\n","                think_body = text.split(\"</think>\")[0]\n","            gt_in_think  = _norm(gt_clean) in _norm(think_body)\n","            pred_correct = _norm(pred) == _norm(gt_clean)\n","            if gt_in_think and not pred_correct:\n","                score = -0.5\n","        scores.append(score)\n","    return scores\n","\n","# ── REWARD 6: SOFT OVERLONG PUNISHMENT (Paper Eq. 13) ────────────────────\n","# When response hits max_completion_length and is truncated,\n","# it receives a soft penalty proportional to truncation severity.\n","# Prevents reward noise from penalizing valid-but-long reasoning chains.\n","# Lcache = buffer zone before hard truncation where penalty ramps up.\n","\n","MAX_COMPLETION_LENGTH = 1536  # Raised from 768 — model needs room to finish reasoning + \\boxed{}\n","LCACHE = 200                  # Penalty ramp-up window (last 200 tokens for longer seqs)\n","\n","def reward_overlong_shaping(completions, **kwargs) -> list:\n","    scores = []\n","    for comp in completions:\n","        text = _get_text(comp)\n","        # Approximate token count (~4 chars per token)\n","        approx_len = len(text) / 4\n","\n","        if approx_len <= (MAX_COMPLETION_LENGTH - LCACHE):\n","            # Response fits cleanly — no penalty\n","            scores.append(0.0)\n","        elif approx_len < MAX_COMPLETION_LENGTH:\n","            # Inside the soft punishment zone — linear ramp\n","            penalty = ((MAX_COMPLETION_LENGTH - LCACHE) - approx_len) / LCACHE\n","            scores.append(penalty)   # Negative value\n","        else:\n","            # At or beyond max — hard truncation penalty\n","            scores.append(-1.0)\n","\n","    return scores\n","\n","print(\"[BAPO] 6-Reward system armed:\")\n","print(\"  reward_format           — max 1.0  (0.5 think + 0.5 boxed)\")\n","print(\"  reward_thinking_quality — max 0.5\")\n","print(\"  reward_correctness      — +4.0 correct | 0.0 no boxed | -1.0 wrong\")\n","print(\"  reward_numerical        — max 3.0  (float equiv, 1% tol, frac/LaTeX aware)\")\n","print(\"  reward_no_hacking       — penalty -0.5 for answer-in-think exploit\")\n","print(\"  reward_overlong_shaping — 0.0 to -1.0 soft truncation penalty\")\n","print(\"  ─────────────────────────\")\n","print(\"  Combined ceiling        : 8.5 pts (1.0+0.5+4.0+3.0+0.0+0.0)\")"]},{"cell_type":"markdown","id":"c8d7466c","metadata":{"papermill":{"duration":0.008721,"end_time":"2026-05-17T12:15:01.190921+00:00","exception":false,"start_time":"2026-05-17T12:15:01.1822+00:00","status":"completed"},"tags":[]},"source":["## Step 3: VRAM Safety Check Before BAPO Training\n","\n","training is more VRAM-hungry than SFT because it holds **G=4 completions** in memory\n","simultaneously during the rollout phase. We check free VRAM before launching and\n","abort with an actionable error if headroom is insufficient."]},{"cell_type":"code","execution_count":19,"id":"6811044a","metadata":{"execution":{"iopub.execute_input":"2026-05-17T12:15:01.208551Z","iopub.status.busy":"2026-05-17T12:15:01.208449Z","iopub.status.idle":"2026-05-17T12:15:01.915219Z","shell.execute_reply":"2026-05-17T12:15:01.914918Z"},"papermill":{"duration":0.716211,"end_time":"2026-05-17T12:15:01.915705+00:00","exception":false,"start_time":"2026-05-17T12:15:01.199494+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["\n"," GPU: NVIDIA RTX PRO 6000 Blackwell Server Edition\n","   Total VRAM:    94.971 GB\n","   Reserved VRAM: 65.674 GB\n","   Free VRAM:     29.30 GB\n","\n"]},{"data":{"image/png":"\n","text/plain":["<Figure size 800x120 with 1 Axes>"]},"metadata":{},"output_type":"display_data"}],"source":["gc.collect()\n","torch.cuda.empty_cache()\n","\n","# 1. Fetch the GPU Hardware Stats\n","gpu_stats = torch.cuda.get_device_properties(0)\n","start_gpu_memory = round(torch.cuda.max_memory_reserved() / 1024 / 1024 / 1024, 3)\n","max_memory = round(gpu_stats.total_memory / 1024 / 1024 / 1024, 3)\n","free_memory = max_memory - start_gpu_memory\n","\n","print(f\"\\n GPU: {gpu_stats.name}\")\n","print(f\"   Total VRAM:    {max_memory} GB\")\n","print(f\"   Reserved VRAM: {start_gpu_memory} GB\")\n","print(f\"   Free VRAM:     {free_memory:.2f} GB\\n\")\n","\n","is_critical = free_memory < 4.0\n","if is_critical:\n","    print(\" WARNING: Less than 4GB free VRAM. Training may OOM.\")\n","    print(\"   Consider reducing MAX_SEQ_LEN or LoRA rank.\")\n","\n","# ==========================================\n","# 2. SEABORN VRAM HUD GRAPH\n","# ==========================================\n","sns.set_theme(style=\"dark\", rc={\n","    \"axes.facecolor\": \"#121212\", \n","    \"figure.facecolor\": \"#121212\",\n","    \"text.color\": \"white\"\n","})\n","\n","# Create a DataFrame for Seaborn to digest\n","df = pd.DataFrame({\n","    'Component': ['VRAM'],\n","    'Used': [start_gpu_memory],\n","    'Total': [max_memory]\n","})\n","\n","f, ax = plot.subplots(figsize=(8, 1.2))\n","\n","# Plot the background bar (Total VRAM / Free Space) in dark gray\n","sns.barplot(x=\"Total\", y=\"Component\", data=df, color=\"#2a2a2a\", ax=ax)\n","\n","# Plot the foreground bar (Used VRAM) overriding the color based on danger levels\n","color_reserved = '#ff3333' if is_critical else '#00e5ff' # Red if critical, Cyan if safe\n","sns.barplot(x=\"Used\", y=\"Component\", data=df, color=color_reserved, ax=ax)\n","\n","# Clean up the axes for the pure HUD look\n","ax.set(ylabel=\"\", xlabel=\"\")\n","ax.set_xticks([])\n","ax.set_yticks([])\n","sns.despine(left=True, bottom=True)\n","\n","# Add dynamic text overlays right inside the bars\n","if start_gpu_memory > 2.0:\n","    plot.text(start_gpu_memory / 2, 0, f\"USED: {start_gpu_memory:.1f} GB\", \n","           