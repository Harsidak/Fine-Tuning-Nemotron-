vs VRAM\n","\n","print(\"✅ Base Model + Tokenizer loaded successfully (BFloat16, no quantization).\")\n","vram_after_load = torch.cuda.max_memory_reserved() / 1024**3\n","print(f\"   VRAM after model load: {vram_after_load:.1f} GB\")\n","\n","# Enable gradient checkpointing BEFORE wrapping with LoRA\n","model.gradient_checkpointing_enable(gradient_checkpointing_kwargs={\"use_reentrant\": False})\n","\n","# Freeze all base model parameters explicitly\n","for param in model.parameters():\n","    param.requires_grad = False\n","\n","print(\"Initializing LoRA adapter (rank 16)...\")\n","lora_config = LoraConfig(\n","    r=16,\n","    lora_alpha=32,\n","    # Target ONLY the Mamba state projections — NOT the MoE expert MLPs.\n","    # MoE has 64 experts; targeting up_proj/down_proj would create billions of\n","    # trainable params and blow up optimizer memory.\n","    target_modules=r\".*\\.(in_proj|out_proj)$\",\n","    # modules_to_save=[\"lm_head\"],  # Train the output head for better \\boxed{} formatting\n","    lora_dropout=0.0,\n","    bias=\"none\",\n","    task_type=TaskType.CAUSAL_LM,\n",")\n","\n","model = get_peft_model(model, lora_config)\n","model.print_trainable_parameters()\n","\n","# Print trainable parameter count\n","trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n","total     = sum(p.numel() for p in model.parameters())\n","print(f\"\\n✅ LoRA adapters attached + gradient checkpointing ON.\")\n","print(f\"   Trainable parameters: {trainable:,} ({100*trainable/total:.2f}% of total)\")\n","print(f\"   Frozen parameters:    {total - trainable:,}\")\n","\n","# Free any lingering memory from loading\n","gc.collect()\n","torch.cuda.empty_cache()"]},{"cell_type":"markdown","id":"08770a3f","metadata":{"papermill":{"duration":0.002139,"end_time":"2026-04-06T08:06:23.554431+00:00","exception":false,"start_time":"2026-04-06T08:06:23.552292+00:00","status":"completed"},"tags":[]},"source":["## DEFINE THE REASONING TRACE FORMAT"]},{"cell_type":"code","execution_count":3,"id":"7349fc34","metadata":{"execution":{"iopub.execute_input":"2026-04-06T08:06:23.559491Z","iopub.status.busy":"2026-04-06T08:06:23.559293Z","iopub.status.idle":"2026-04-06T08:06:23.564333Z","shell.execute_reply":"2026-04-06T08:06:23.564076Z"},"papermill":{"duration":0.008189,"end_time":"2026-04-06T08:06:23.564774+00:00","exception":false,"start_time":"2026-04-06T08:06:23.556585+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["import re\n","\n","# Strict Regex to capture \\boxed{} and its contents (supports one level of nesting)\n","BOXED_PATTERN = re.compile(r\"\\\\boxed\\{[^{}]*(?:\\{[^{}]*\\}[^{}]*)*\\}\")\n","\n","# --- System prompts ---\n","REASONING_ON_SYSTEM  = \"detailed thinking on\"\n","REASONING_OFF_SYSTEM = \"detailed thinking off\"\n","\n","REASONING_TEMPLATE = (\n","    \"<|im_start|>system\\n\"\n","    \"{system_prompt}<|im_end|>\\n\"\n","    \"<|im_start|>user\\n\"\n","    \"{question}<|im_end|>\\n\"\n","    \"<|im_start|>assistant\\n\"\n","    \"<think>\\n\"\n","    \"{chain_of_thought}\\n\"\n","    \"</think>\\n\"\n","    \"{final_answer}<|im_end|>\"\n",")\n","\n","NON_REASONING_TEMPLATE = (\n","    \"<|im_start|>system\\n\"\n","    \"{system_prompt}<|im_end|>\\n\"\n","    \"<|im_start|>user\\n\"\n","    \"{question}<|im_end|>\\n\"\n","    \"<|im_start|>assistant\\n\"\n","    \"{final_answer}<|im_end|>\"\n",")\n","\n","def normalize_columns(example):\n","    \"\"\"Translate any dataset's column names to standard 'question' and 'answer'.\"\"\"\n","    question = (example.get(\"problem\") or example.get(\"question\") or\n","                example.get(\"instruction\") or example.get(\"prompt\") or \"\")\n","    answer = (example.get(\"solution\") or example.get(\"response\") or\n","              example.get(\"answer\") or example.get(\"output\") or \"\")\n","    return {\"question\": str(question).strip(), \"answer\": str(answer).strip()}\n","\n","def format_sample(example):\n","    \"\"\"Universal formatter — auto-detects the best template.\"\"\"\n","    q = example.get(\"question\", \"\")\n","    a = example.get(\"answer\", \"\")\n","\n","    if not q or not a or len(a.strip()) < 5:\n","        return {\"text\": \"\", \"is_valid\": False}\n","\n","    box_match = BOXED_PATTERN.search(a)\n","    has_think = \"<think>\" in a and \"</think>\" in a\n","\n","    if box_match:\n","        final_answer = box_match.group(0)\n","        if has_think:\n","            cot = a.split(\"<think>\")[-1].split(\"</think>\")[0].strip()\n","        else:\n","            cot = a.split(final_answer)[0].strip()\n","        cot = cot.replace(\"<think>\", \"\").replace(\"</think>\", \"\").strip()\n","        if cot:\n","            text = REASONING_TEMPLATE.format(\n","                system_prompt=REASONING_ON_SYSTEM, question=q,\n","                chain_of_thought=cot, final_answer=final_answer)\n","        else:\n","            text = NON_REASONING_TEMPLATE.format(\n","                system_prompt=REASONING_OFF_SYSTEM, question=q,\n","                final_answer=final_answer)\n","    elif has_think:\n","        cot = a.split(\"<think>\")[-1].split(\"</think>\")[0].strip()\n","        final_answer = a.split(\"</think>\")[-1].strip() or a\n","        cot = cot.replace(\"<think>\", \"\").replace(\"</think>\", \"\").strip()\n","        text = REASONING_TEMPLATE.format(\n","            system_prompt=REASONING_ON_SYSTEM, question=q,\n","            chain_of_thought=cot, final_answer=final_answer)\n","    else:\n","        text = NON_REASONING_TEMPLATE.format(\n","            system_prompt=REASONING_OFF_SYSTEM, question=q,\n","            final_answer=a)\n","\n","    return {\"text\": text, \"is_valid\": True}"]},{"cell_type":"markdown","id":"62ba506d","metadata":{"papermill":{"duration":0.002099,"end_time":"2026-04-06T08:06:23.569061+00:00","exception":false,"start_time":"2026-04-06T08:06:23.566962+00:00","status":"completed"},"tags":[]},"source":["## LOAD AND FORMAT THE DATASET"]