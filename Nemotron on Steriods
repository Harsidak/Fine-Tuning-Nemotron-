y vs VRAM\n","\n","print(\"✅ Base Model + Tokenizer loaded successfully (BFloat16, no quantization).\")\n","vram_after_load = torch.cuda.max_memory_reserved() / 1024**3\n","print(f\"   VRAM after model load: {vram_after_load:.1f} GB\")\n","\n","# Enable gradient checkpointing BEFORE wrapping with LoRA\n","model.gradient_checkpointing_enable(gradient_checkpointing_kwargs={\"use_reentrant\": False})\n","\n","# Freeze all base model parameters explicitly\n","for param in model.parameters():\n","    param.requires_grad = False\n","\n","print(\"Initializing LoRA adapter (rank 16)...\")\n","lora_config = LoraConfig(\n","    r=16,\n","    lora_alpha=32,\n","    # Target ONLY the Mamba state projections — NOT the MoE expert MLPs.\n","    # MoE has 64 experts; targeting up_proj/down_proj would create billions of\n","    # trainable params and blow up optimizer memory.\n","    target_modules=r\".*\\.(in_proj|out_proj)$\",\n","    # modules_to_save=[\"lm_head\"],  # Train the output head for better \\boxed{} formatting\n","    lora_dropout=0.0,\n","    bias=\"none\",\n","    task_type=TaskType.CAUSAL_LM,\n",")\n","\n","model = get_peft_model(model, lora_config)\n","model.print_trainable_parameters()\n","\n","# Print trainable parameter count\n","trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\n","total     = sum(p.numel() for p in model.parameters())\n","print(f\"\\n✅ LoRA adapters attached + gradient checkpointing ON.\")\n","print(f\"   Trainable parameters: {trainable:,} ({100*trainable/total:.2f}% of total)\")\n","print(f\"   Frozen parameters:    {total - trainable:,}\")\n","\n","# Free any lingering memory from loading\n","gc.collect()\n","torch.cuda.empty_cache()"]},{"cell_type":"markdown","id":"e1c5c0da","metadata":{"papermill":{"duration":0.002078,"end_time":"2026-04-05T16:23:18.496461+00:00","exception":false,"start_time":"2026-04-05T16:23:18.494383+00:00","status":"completed"},"tags":[]},"source":["## DEFINE THE REASONING TRACE FORMAT"]},{"cell_type":"code","execution_count":3,"id":"bc805547","metadata":{"execution":{"iopub.execute_input":"2026-04-05T16:23:18.501393Z","iopub.status.busy":"2026-04-05T16:23:18.501239Z","iopub.status.idle":"2026-04-05T16:23:18.506379Z","shell.execute_reply":"2026-04-05T16:23:18.506164Z"},"papermill":{"duration":0.008257,"end_time":"2026-04-05T16:23:18.506805+00:00","exception":false,"start_time":"2026-04-05T16:23:18.498548+00:00","status":"completed"},"tags":[]},"outputs":[],"source":["import re\n","\n","# Strict Regex to capture \\boxed{} and its contents (supports one level of nesting)\n","BOXED_PATTERN = re.compile(r\"\\\\boxed\\{[^{}]*(?:\\{[^{}]*\\}[^{}]*)*\\}\")\n","\n","# --- System prompts ---\n","REASONING_ON_SYSTEM  = \"detailed thinking on\"\n","REASONING_OFF_SYSTEM = \"detailed thinking off\"\n","\n","REASONING_TEMPLATE = \"\"\"<|im_start|>system\n","{system_prompt}<|im_end|>\n","<|im_start|>user\n","{question}<|im_end|>\n","<|im_start|>assistant\n","<think>\n","{chain_of_thought}\n","</think>\n","{final_answer}<|im_end|>\"\"\"\n","\n","NON_REASONING_TEMPLATE = \"\"\"<|im_start|>system\n","{system_prompt}<|im_end|>\n","<|im_start|>user\n","{question}<|im_end|>\n","<|im_start|>assistant\n","{final_answer}<|im_end|>\"\"\"\n","\n","def normalize_columns(example):\n","    \"\"\"\n","    Translate any dataset's column names to standard 'question' and 'answer'.\n","    Handles: NuminaMath (problem/solution), Magpie (instruction/response),\n","             Dolphin (instruction/output), and others.\n","    \"\"\"\n","    question = (example.get(\"problem\") or example.get(\"question\") or\n","                example.get(\"instruction\") or example.get(\"prompt\") or \"\")\n","    answer = (example.get(\"solution\") or example.get(\"response\") or\n","              example.get(\"answer\") or example.get(\"output\") or \"\")\n","    return {\"question\": str(question).strip(), \"answer\": str(answer).strip()}\n","\n","\n","def format_sample(example):\n","    \"\"\"\n","    Universal formatter — auto-detects the best template:\n","      1. Has \\\\boxed{} → Math reasoning mode (with <think> block)\n","      2. Has <think> tags → Extract existing reasoning trace\n","      3. Neither → Direct Q&A mode (non-reasoning template)\n","    \"\"\"\n","    q = example.get(\"question\", \"\")\n","    a = example.get(\"answer\", \"\")\n","\n","    if not q or not a or len(a.strip()) < 5:\n","        return {\"text\": \"\", \"is_valid\": False}\n","\n","    box_match = BOXED_PATTERN.search(a)\n","    has_think = \"<think>\" in a and \"</think>\" in a\n","\n","    if box_match:\n","        # ═══ MATH MODE: Extract boxed answer, build reasoning trace ═══\n","        final_answer = box_match.group(0)\n","        if has_think:\n","            cot = a.split(\"<think>\")[-1].split(\"</think>\")[0].strip()\n","        else:\n","            cot = a.split(final_answer)[0].strip()\n","        cot = cot.replace(\"<think>\", \"\").replace(\"</think>\", \"\").strip()\n","\n","        if cot:\n","            text = REASONING_TEMPLATE.format(\n","                system_prompt=REASONING_ON_SYSTEM, question=q,\n","                chain_of_thought=cot, final_answer=final_answer)\n","        else:\n","            text = NON_REASONING_TEMPLATE.format(\n","                system_prompt=REASONING_OFF_SYSTEM, question=q,\n","                final_answer=final_answer)\n","\n","    elif has_think:\n","        # ═══ REASONING MODE: Has think tags but no boxed answer ═══\n","        cot = a.split(\"<think>\")[-1].split(\"</think>\")[0].strip()\n","        final_answer = a.split(\"</think>\")[-1].strip() or a\n","        cot = cot.replace(\"<think>\", \"\").replace(\"</think>\", \"\").strip()\n","        text = REASONING_TEMPLATE.format(\n","            system_prompt=REASONING_ON_SYSTEM, question=q,\n","            chain_of_thought=cot, final_answer=final_answer)\n","\n","    else:\n","        # ═══ GENERAL MODE: Direct Q&A (code, logic, etc.) ═══\n","        text = NON_REASONING_TEMPLATE.format(\n","            system_prompt=REASONING_OFF_SYSTEM, question=q,\n","            final_answer=a)\n","\n","    return {\"text\": text, \"is_valid\": True}"]},{"cell_type":"markdown","id":"fa592c5a","metadata":{"papermill":{"duration":0.002076,"end_time":"2026-04-05T16:23:18.511054+00:00","exception":false,"start_time":"2026-04-05T16:23:18.508978+00:00","status":"completed"},"tags":[]},"source":["## LOAD AND FORMAT THE DATASET"]},{"cell_type":"code","execution_count":4,"id":"bdc0b1fe","metadata":{"execution":{"iopub.execute_input":"2026-04-05T16:23:18.515835Z","iopub.status.busy":"2026-04-05T16:23:18.515688Z","iopub.status.idle":"2026-04-05T16:25:06.651049Z","shell.execute_reply":"2026-04-05T16:25:06.650624Z"},"papermill":{"duration":108.138497,"end_time":"2026-04-05T16:25:06.651637+00:00","exception":false,"start_time":"2026-04-05T16:23:18.51314+00:00","status":"completed"},"tags":[]},"outputs":[{"name":"stdout","output_type":"stream","text":["\n","📦 Loading Offline Datasets from /kaggle/input ...\n","   ⏳ Streaming NuminaMath-CoT from /kaggle/input/notebooks/banwait13/datasets-for-nemotron-banwait/numinamath_data/data.parquet...\n","   ✅ NuminaMath-CoT: Materialized 5,000 rows | Columns: ['source', 'problem', 'solution', 'messages']\n","   ⏳ Streaming Magpie Logic from /kaggle/input/notebooks/banwait13/datasets-for-nemotron-banwait/magpie_logic_data/data.parquet...\n","   ✅ Magpie Logic: Materialized 5,000 rows | Columns: ['uuid', 'instruction', 'response', 'conversations', 'gen_input_configs', 'gen_response_configs', 'intent', 'knowledge', 'difficulty', 'difficulty_generator', 'input_quality', 'quality_explanation', 'quality_generator', 'task_category', 'other_task_category', 'task_category_generator', 'language']\n","   ⏳ Streaming Dolphin Code from /kaggle/input/notebooks/banwait13/datasets-for-nemotron-banwait/dolphin_code_data/data.parquet...\n","   ✅ Dolphin Code: Materialized 5,000 rows | Columns: ['system_prompt', 'question', 'response']\n","\n","   Combined raw samples: 15,000\n","   Applying formatting + quality filter...\n","\n","   ✅ Final SURVIVING training samples: 15,000\n","\n","📋 Sample Preview (first 500 chars):\n","<|im_start|>system\n","detailed thinking off<|im_end|>\n","<|im_start|>user\n","Let $n$ be a positive integer. Prove that the number of permutations $p$ of the set $\\{1, 2, ..., n\\}$ for which $|p(i) - i| \\leq 2$ for every $i$ is given by the expression $\\sum_{k=0}^{\\lfloor\\frac{n}{3}\\rfloor}{{n-2k \\choose 3k}}{3k \\choose k}3^k$.<|im_end|>\n","<|im_start|>assistant\n","We can prove this by induction on $n$. For $n=1$, there is only one permutation, which satisfies the condition, so the formula holds. Now, assume th...\n","\n"]}],"source":["import datasets\n","from datasets import load_dataset, concatenate_datasets, Dataset\n","\n","# Prevent huggingface from logging thousands of progress bar lines, which crashes papermill\n","datasets.utils.logging.disable_progress_bar()\n","\n","print(\"\\n📦 Loading Offline Datasets from /kaggle/input ...\")\n","\n","# ── Dataset paths (pre-downloaded via separate notebook) ──\n","NUMINA_PATH  = \"/kaggle/input/notebooks/banwait13/datasets-for-nemotron-banwait/numinamath_data/data.parquet\"\n","MAGPIE_PATH  = \"/kaggle/input/notebooks/banwait13/datasets-for-nemotron-banwait/magpie_logic_data/data.parquet\"\n","DOLPHIN_PATH = \"/kaggle/input/notebooks/banwait13/datasets-for-nemotron-banwait/dolphin_code_data/data.parquet\"\n","\n","MAX_SAMPLES_PER_SOURCE = 5000  # Cap per dataset to keep Phase 1 fast\n","\n","def load_parquet_safe(path, name, max_samples=MAX_SAMPLES_PER_SOURCE):\n","    \"\"\"Load a parquet file safely safely using streaming to prevent multi-GB cache explosions.\"\"\"\n","    try:\n","        print(f\"   ⏳ Streaming {name} from {path}...\")\n","        ds_stream = load_dataset(\"parquet\", data_files=path, split=\"train\", streaming=True)\n","        \n","        # Take only the max_samples and materialize them to