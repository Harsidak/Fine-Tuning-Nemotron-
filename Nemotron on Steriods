{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.12","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"none","dataSources":[{"sourceType":"competition","sourceId":129716,"databundleVersionId":16082784},{"sourceType":"datasetVersion","sourceId":14799391,"datasetId":9184804,"databundleVersionId":15654315},{"sourceType":"modelInstanceVersion","sourceId":784907,"databundleVersionId":16059913,"modelInstanceId":598905,"modelId":611168},{"sourceType":"kernelVersion","sourceId":306236690},{"sourceType":"kernelVersion","sourceId":309127063}],"isInternetEnabled":false,"language":"python","sourceType":"notebook","isGpuEnabled":false}},"nbformat_minor":4,"nbformat":4,"cells":[{"source":"<a href=\"https://www.kaggle.com/code/banwait13/nemotron-on-steroids?scriptVersionId=309135972\" target=\"_blank\"><img align=\"left\" alt=\"Kaggle\" title=\"Open in Kaggle\" src=\"https://kaggle.com/static/images/open-in-kaggle.svg\"></a>","metadata":{},"cell_type":"markdown"},{"cell_type":"markdown","source":"# SECTION - 0 : INTRODUCTION\n**This is the Full pipeline for fine-tuning our model (Nemotron).**\n1. Phase 1 SFT: We are going to use a common pile data set for fine-tuning our model.\n2. Phase - 2 We are going to use Reasoning, Maths, or any other specialized datasets to increase the reasoning of the model.\n3. Phase 3: Finally, we are going to use GRPO","metadata":{}},{"cell_type":"markdown","source":"Downloading The necessary imports ","metadata":{}},{"cell_type":"code","source":"import numpy as np \nimport pandas as pd \nimport matplotlib.pyplot as plot\nimport seaborn as sns\nimport os\nimport kagglehub\nimport gc\nimport re\nimport subprocess\nimport shutil\nimport glob\nptxas_fix_dir = \"/kaggle/working/_ptxas_fix\"\nos.makedirs(ptxas_fix_dir, exist_ok=True)\n\nptxas_bins = glob.glob(\"/kaggle/usr/lib/**/ptxas*\", recursive=True)\nfor src in ptxas_bins:\n    if os.path.isfile(src):\n        dst = os.path.join(ptxas_fix_dir, os.path.basename(src))\n        shutil.copy2(src, dst)\n        os.chmod(dst, 0o755)\n\n# Monkeypatch subprocess.Popen to reroute all executions of read-only ptxas\n_orig_Popen = subprocess.Popen\nclass PatchedPopen(_orig_Popen):\n    def __init__(self, args, *pargs, **kwargs):\n        if isinstance(args, (list, tuple)) and len(args) > 0 and isinstance(args[0], str):\n            if \"ptxas\" in args[0] and \"/kaggle/usr/lib/\" in args[0]:\n                args = list(args)\n                args[0] = os.path.join(ptxas_fix_dir, os.path.basename(args[0]))\n        elif isinstance(args, str):\n            if \"ptxas\" in args and \"/kaggle/usr/lib/\" in args:\n                args = re.sub(r'/kaggle/usr/lib/\\S+/ptxas\\S*', lambda m: os.path.join(ptxas_fix_dir, os.path.basename(m.group(0))), args)\n        super().__init__(args, *pargs, **kwargs)\n\nsubprocess.Popen = PatchedPopen\n\nif ptxas_bins:\n    print(f\"🔧 Copied & fixed {len(ptxas_bins)} ptxas binaries. Subprocess hook active.\")\n\nimport sys\nbnb_wheels = glob.glob(\"/kaggle/input/**/*.whl\", recursive=True)\nbnb_wheel = next((w for w in bnb_wheels if \"bitsandbytes\" in w.lower()), None)\n\nif bnb_wheel:\n    print(f\"📦 Found bitsandbytes wheel at: {bnb_wheel}\")\n    try:\n        subprocess.check_call([\n            sys.executable, \"-m\", \"pip\", \"install\", \"--no-index\", \"--find-links\", \n            os.path.dirname(bnb_wheel), \"bitsandbytes\"\n        ])\n        print(\"✅ bitsandbytes offline install complete!\")\n    except subprocess.CalledProcessError as e:\n        print(f\"⚠️ Offline install failed: {e}\")\nelse:\n    print(\"⚠️ WARNING: bitsandbytes wheel NOT FOUND in /kaggle/input! Make sure you attached the dataset.\")\n\nimport torch\nfrom peft import LoraConfig, get_peft_model, TaskType\nfrom transformers import AutoModelForCausalLM, AutoTokenizer, BitsAndBytesConfig\nimport site\n\nfor dirname, _, filenames in os.walk('/kaggle/input'):\n    for filename in filenames:\n        pass\n\ncutlass_pkg_path = \"/kaggle/usr/lib/notebooks/ryanholbrook/nvidia-utility-script/nvidia_cutlass_dsl/python_packages/\"\nsite.addsitedir(cutlass_pkg_path)\nOUTPUT_DIR = \"/kaggle/working\"","metadata":{"_uuid":"8f2839f25d086af736a60e9eeb907d3b93b6e0e5","_cell_guid":"b1076dfc-b9ad-4769-8c92-a6c4dae69d19","trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# SECTION - 1: FINE TUNING","metadata":{}},{"cell_type":"markdown","source":"## LOAD THE MODEL + TOKENIZER\nWhat is happening here (simple version):\n1. We load the 4B Nemotron model in 4-bit quantization. \n2. 4-bit means we compress the model's numbers to save VRAM. \n3. The model goes from ~8GB to ~3GB. It fits on a T4 GPU now.","metadata":{}},{"cell_type":"code","source":"# 1. Clear the runway\ngc.collect()\ntorch.cuda.empty_cache()\n\n# 2. Link the Organizer's pre-built engine\ncutlass_pkg_path = \"/kaggle/usr/lib/notebooks/ryanholbrook/nvidia_utility_script/nvidia_cutlass_dsl/python_packages/\"\nsite.addsitedir(cutlass_pkg_path)\n\n# 3. Native Kaggle Mount\nMODEL_PATH = \"/kaggle/input/models/metric/nemotron-3-nano-30b-a3b-bf16/transformers/default/1\"\n\nfrom transformers import BitsAndBytesConfig\n\n# Configure 8-bit quantization\nquant_config = BitsAndBytesConfig(\n    load_in_8bit=True,\n    # The following are optional but highly recommended for 8-bit training\n    llm_int8_threshold=6.0,\n    llm_int8_has_fp16_weight=False,\n)\n\nmodel = AutoModelForCausalLM.from_pretrained(\n    MODEL_PATH,\n    device_map=\"auto\", \n    trust_remote_code=True,\n    low_cpu_mem_usage=True,\n    quantization_config=quant_config,\n    # Note: torch_dtype is still required so the active computation happens in 16-bit\n    torch_dtype=torch.bfloat16 \n)\n\n# 5. Load tokenizer from the same offline mount\ntokenizer = AutoTokenizer.from_pretrained(MODEL_PATH, trust_remote_code=True)\ntokenizer.pad_token = tokenizer.eos_token\ntokenizer.padding_side = \"right\"\nMAX_SEQ_LEN = 2048  # Safe for 30B MoE on RTX 6000 Pro 48GB\n\nprint(\"✅ Base Model + Tokenizer loaded successfully.\")\n\nprint(\"Initializing LoRA adapter...\")\nlora_config = LoraConfig(\n    r=32,\n    lora_alpha=64,\n    target_modules=r\".*\\.(in_proj|out_proj|up_proj|down_proj)$\",\n    lora_dropout=0.0,\n    bias=\"none\",\n    task_type=TaskType.CAUSAL_LM,\n)\n\nmodel = get_peft_model(model, lora_config)\n\n# CRITICAL: Gradient checkpointing saves ~40% VRAM on this 30B model\nmodel.gradient_checkpointing_enable(gradient_checkpointing_kwargs={\"use_reentrant\": False})\nmodel.print_trainable_parameters()\n\n# Print trainable parameter count\ntrainable = sum(p.numel() for p in model.parameters() if p.requires_grad)\ntotal     = sum(p.numel() for p in model.parameters())\nprint(f\"\\n✅ LoRA adapters attached + gradient checkpointing ON.\")\nprint(f\"   Trainable parameters: {trainable:,} ({100*trainable/total:.2f}% of total)\")\nprint(f\"   Frozen parameters:    {total - trainable:,}\")\n\n# Free any lingering memory from loading\ngc.collect()\ntorch.cuda.empty_cache()","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## DEFINE THE REASONING TRACE FORMAT","metadata":{}},{"cell_type":"code","source":"import re\n\n# Strict Regex to capture \\boxed{} and its contents (supports one level of nesting)\nBOXED_PATTERN = re.compile(r\"\\\\boxed\\{[^{}]*(?:\\{[^{}]*\\}[^{}]*)*\\}\")\n\n# --- System prompts ---\nREASONING_ON_SYSTEM  = \"detailed thinking on\"\nREASONING_OFF_SYSTEM = \"detailed thinking off\"\n\nREASONING_TEMPLATE = \"\"\"<|im_start|>system\n{system_prompt}<|im_end|>\n<|im_start|>user\n{question}<|im_end|>\n<|im_start|>assistant\n<think>\n{chain_of_thought}\n</think>\n{final_answer}<|im_end|>\"\"\"\n\nNON_REASONING_TEMPLATE = \"\"\"<|im_start|>system\n{system_prompt}<|im_end|>\n<|im_start|>user\n{question}<|im_end|>\n<|im_start|>assistant\n{final_answer}<|im_end|>\"\"\"\n\ndef normalize_columns(example):\n    \"\"\"\n    Translate any dataset's column names to standard 'question' and 'answer'.\n    Handles: NuminaMath (problem/solution), Magpie (instruction/response),\n             Dolphin (instruction/output), and others.\n    \"\"\"\n    question = (example.get(\"problem\") or example.get(\"question\") or\n                example.get(\"instruction\") or example.get(\"prompt\") or \"\")\n    answer = (example.get(\"solution\") or example.get(\"response\") or\n              example.get(\"answer\") or example.get(\"output\") or \"\")\n    return {\"question\": str(question).strip(), \"answer\": str(answer).strip()}\n\n\ndef format_sample(example):\n    \"\"\"\n    Universal formatter — auto-detects the best template:\n      1. Has \\\\boxed{} → Math reasoning mode (with <think> block)\n      2. Has <think> tags → Extract existing reasoning trace\n      3. Neither → Direct Q&A mode (non-reasoning template)\n    \"\"\"\n    q = example.get(\"question\", \"\")\n    a = example.get(\"answer\", \"\")\n\n    if not q or not a or len(a.strip()) < 5:\n        return {\"text\": \"\", \"is_valid\": False}\n\n    box_match = BOXED_PATTERN.search(a)\n    has_think = \"<think>\" in a and \"</think>\" in a\n\n    if box_match:\n        # ═══ MATH MODE: Extract boxed answer, build reasoning trace ═══\n        final_answer = box_match.group(0)\n        if has_think:\n            cot = a.split(\"<think>\")[-1].split(\"</think>\")[0].strip()\n        else:\n            cot = a.split(final_answer)[0].strip()\n        cot = cot.replace(\"<think>\", \"\").replace(\"</think>\", \"\").strip()\n\n        if cot:\n            text = REASONING_TEMPLATE.format(\n                system_prompt=REASONING_ON_SYSTEM, question=q,\n                chain_of_thought=cot, final_answer=final_answer)\n        else:\n            text = NON_REASONING_TEMPLATE.format(\n                system_prompt=REASONING_OFF_SYSTEM, question=q,\n                final_answer=final_answer)\n\n    elif has_think:\n        # ═══ REASONING MODE: Has think tags but no boxed answer ═══\n        cot = a.split(\"<think>\")[-1].split(\"</think>\")[0].strip()\n        final_answer = a.split(\"</think>\")[-1].strip() or a\n        cot = cot.replace(\"<think>\", \"\").replace(\"</think>\", \"\").strip()\n        text = REASONING_TEMPLATE.format(\n            system_prompt=REASONING_ON_SYSTEM, question=q,\n            chain_of_thought=cot, final_answer=final_answer)\n\n    else:\n        # ═══ GENERAL MODE: Direct Q&A (code, logic, etc.) ═══\n        text = NON_REASONING_TEMPLATE.format(\n            system_prompt=REASONING_OFF_SYSTEM, question=q,\n            final_answer=a)\n\n    return {\"text\": text, \"is_valid\": True}","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## LOAD AND FORMAT THE DATASET","metadata":{}},{"cell_type":"code","source":"import datasets\nfrom datasets import load_dataset, concatenate_datasets, Dataset\n\n# Prevent huggingface from logging thousands of progress bar lines, which crashes papermill\ndatasets.utils.logging.disable_progress_bar()\n\nprint(\"\\n📦 Loading Offline Datasets from /kaggle/input ...\")\n\n# ── Dataset paths (pre-downloaded via separate notebook) ──\nNUMINA_PATH  = \"/kaggle/input/notebooks/banwait13/datasets-for-nemotron-banwait/numinamath_data/data.parquet\"\nMAGPIE_PATH  = \"/kaggle/input/notebooks/banwait13/datasets-for-nemotron-banwait/magpie_logic_data/data.parquet\"\nDOLPHIN_PATH = \"/kaggle/input/notebooks/banwait13/datasets-for-nemotron-banwait/dolphin_code_data/data.parquet\"\n\nMAX_SAMPLES_PER_SOURCE = 5000  # Cap per dataset to keep Phase 1 fast\n\ndef load_parquet_safe(path, name, max_samples=MAX_SAMPLES_PER_SOURCE):\n    \"\"\"Load a parquet file safely safely using streaming to prevent multi-GB cache explosions.\"\"\"\n    try:\n        print(f\"   ⏳ Streaming {name} from {path}...\")\n        ds_stream = load_dataset(\"parquet\", data_files=path, split=\"train\", streaming=True)\n        \n        # Take only the max_samples and materialize them to memory (bypasses disk cache completely)\n        ds_list = list(ds_stream.take(max_samples))\n        ds = Dataset.from_list(ds_list)\n        \n        print(f\"   ✅ {name}: Materialized {len(ds):,} rows | Columns: {ds.column_names}\")\n        return ds\n    except Exception as e:\n        print(f\"   ❌ {name}: FAILED to load — {e}\")\n        return None\n\nd_numina  = load_parquet_safe(NUMINA_PATH,  \"NuminaMath-CoT\")\nd_magpie  = load_parquet_safe(MAGPIE_PATH,  \"Magpie Logic\")\nd_dolphin = load_parquet_safe(DOLPHIN_PATH, \"Dolphin Code\")\n\n# ── Normalize columns across all datasets to standard question/answer ──\nall_datasets = []\nfor name, ds in [(\"NuminaMath\", d_numina), (\"Magpie\", d_magpie), (\"Dolphin\", d_dolphin)]:\n    if ds is not None:\n        ds = ds.map(normalize_columns, num_proc=2, desc=f\"Normalizing {name}\")\n        all_datasets.append(ds)\n\nif not all_datasets:\n    raise RuntimeError(\"❌ No datasets loaded! Check file paths under /kaggle/input/\")\n\ndataset = concatenate_datasets(all_datasets)\ndataset = dataset.shuffle(seed=3407)\nprint(f\"\\n   Combined raw samples: {len(dataset):,}\")\n\n# ── Apply universal formatting ──\nprint(\"   Applying formatting + quality filter...\")\ndataset = dataset.map(format_sample, num_proc=2, desc=\"Formatting\")\ndataset = dataset.filter(lambda x: x[\"is_valid\"])\n\n# ── Fast length filter (char-based heuristic: ~4 chars per token) ──\nMAX_CHAR_LEN = MAX_SEQ_LEN * 4  # ~8192 chars ≈ 2048 tokens\ndataset = dataset.filter(lambda x: 0 < len(x[\"text\"]) <= MAX_CHAR_LEN)\n\n# ── Clean up columns for Trainer ──\nkeep_cols = {\"text\"}\ndrop_cols = [c for c in dataset.column_names if c not in keep_cols]\nif drop_cols:\n    dataset = dataset.remove_columns(drop_cols)\n\n# Free memory from raw dataset loading\ndel all_datasets, d_numina, d_magpie, d_dolphin\ngc.collect()\n\nprint(f\"\\n   ✅ Final SURVIVING training samples: {len(dataset):,}\")\nif len(dataset) > 0:\n    print(\"\\n📋 Sample Preview (first 500 chars):\")\n    print(dataset[0][\"text\"][:500] + \"...\\n\")\nelse:\n    print(\"\\n⚠️  ALL SAMPLES DISCARDED! Check column names or data format.\\n\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## TOKENISING THE DATASET","metadata":{}},{"cell_type":"code","source":"print(\"🔢 Tokenizing dataset...\")\n\ndef tokenize_fn(examples):\n    \"\"\"Tokenize text for causal LM training.\"\"\"\n    return tokenizer(\n        examples[\"text\"],\n        truncation=True,\n        max_length=MAX_SEQ_LEN,\n        padding=False,\n    )\n\ntokenized_dataset = dataset.map(\n    tokenize_fn,\n    batched=True,\n    remove_columns=dataset.column_names,\n    num_proc=2,\n    desc=\"Tokenizing\",\n)\n\n# Free the raw text dataset from memory\ndel dataset\ngc.collect()\n\nprint(f\"   ✅ Tokenized samples: {len(tokenized_dataset):,}\")\nif len(tokenized_dataset) > 0:\n    sample_len = len(tokenized_dataset[0][\"input_ids\"])\n    print(f\"   First sample length: {sample_len} tokens\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## CONFIGURE THE TRAINER","metadata":{}},{"cell_type":"code","source":"\nfrom transformers import Trainer, TrainingArguments, DataCollatorForLanguageModeling\n\n# --- Data collator handles dynamic padding + label creation ---\ndata_collator = DataCollatorForLanguageModeling(\n    tokenizer=tokenizer,\n    mlm=False,  # Causal LM, not masked LM\n)\n\n# --- Training hyperparameters (tuned for RTX 6000 Pro + 30B MoE) ---\nBATCH_SIZE            = 1      # 30B model is large — 1 sample per step is safest\nGRAD_ACCUMULATION     = 8      # Effective batch = 1×8 = 8\nWARMUP_STEPS          = 30     # Slowly ramp up learning rate\nMAX_STEPS             = 500    # Quick Phase 1 baseline. Use 500-1000 for full run.\nLEARNING_RATE         = 1e-4   # Standard for LoRA fine-tuning\n# SAVE_STEPS            = 100    # Less frequent saves = less disk usage\nSFT_OUTPUT_DIR        = \"/kaggle/working/nemotron_sft_output\"\n\ntraining_args = TrainingArguments(\n    per_device_train_batch_size  = BATCH_SIZE,\n    gradient_accumulation_steps  = GRAD_ACCUMULATION,\n    warmup_steps                 = WARMUP_STEPS,\n    max_steps                    = MAX_STEPS,\n    learning_rate                = LEARNING_RATE,\n    bf16                         = True,\n    fp16                         = False, \n    logging_steps                = 10,\n    optim                        = \"adamw_torch_fused\",      # 8-bit optimizer saves ~30% VRAM\n    weight_decay                 = 0.01,\n    lr_scheduler_type            = \"cosine\",\n    seed                         = 3407,\n    output_dir                   = SFT_OUTPUT_DIR,\n    # save_steps                   = SAVE_STEPS,\n    # save_total_limit             = 2,     # Keep ONLY 2 checkpoints (disk safety)\n    save_strategy                = \"no\",\n    report_to                    = \"none\",\n    disable_tqdm                 = True,\n    gradient_checkpointing       = True,\n    gradient_checkpointing_kwargs = {\"use_reentrant\": False},\n    dataloader_pin_memory        = False, # Saves host memory\n    dataloader_num_workers       = 0,  # Avoid multiprocess memory overhead\n    remove_unused_columns        = False,\n    max_grad_norm                = 1.0,               # Gradient clipping for stability\n)\n\ntrainer = Trainer(\n    model           = model,\n    args            = training_args,\n    train_dataset   = tokenized_dataset,\n    data_collator   = data_collator,\n)\n\nprint(\"✅ Trainer configured.\")\nprint(f\"   Effective batch size: {BATCH_SIZE * GRAD_ACCUMULATION}\")\nprint(f\"   Max training steps:   {MAX_STEPS}\")\nprint(f\"   Learning rate:        {LEARNING_RATE}\")\nprint(f\"   Precision:            BP16\")\nprint(f\"   Optimizer:            adamw_torch_fused\")","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## VRAM CHECK BEFORE LAUNCH","metadata":{}},{"cell_type":"code","source":"\ngc.collect()\ntorch.cuda.empty_cache()\n\ngpu_stats = torch.cuda.get_device_properties(0)\nstart_gpu_memory = round(torch.cuda.max_memory_reserved() / 1024 / 1024 / 1024, 3)\nmax_memory = round(gpu_stats.total_memory / 1024 / 1024 / 1024, 3)\n\nprint(f\"\\n🖥️  GPU: {gpu_stats.name}\")\nprint(f\"   Total VRAM:    {max_memory} GB\")\nprint(f\"   Reserved VRAM: {start_gpu_memory} GB\")\nprint(f\"   Free VRAM:     {max_memory - start_gpu_memory:.2f} GB\")\n\nif max_memory - start_gpu_memory < 4.0:\n    print(\"⚠️  WARNING: Less than 4GB free VRAM. Training may OOM.\")\n    print(\"   Consider reducing MAX_SEQ_LEN or LoRA rank.\")\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## TRAINING THE MODEL","metadata":{}},{"cell_type":"code","source":"print(\"\\n🚀 COMMENCING PHASE 1 TRAINING...\\n\")\ntrainer_stats = trainer.train()\n\n# --- Post-training VRAM report ---\nused_memory     = round(torch.cuda.max_memory_reserved() / 1024 / 1024 / 1024, 3)\nused_memory_lora= round(used_memory - start_gpu_memory, 3)\npct_memory      = round(used_memory / max_memory * 100, 3)\n\nprint(f\"\\n✅ TRAINING COMPLETE.\")\nprint(f\"   Peak VRAM used:     {used_memory} GB ({pct_memory}% of total)\")\nprint(f\"   VRAM for training:  {used_memory_lora} GB\")\nprint(f\"   Training time:      {trainer_stats.metrics['train_runtime']:.2f} seconds\")\nprint(f\"   Training loss:      {trainer_stats.metrics['train_loss']:.4f}\")\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## SAVING THE LoRA ADAPTER","metadata":{}},{"cell_type":"code","source":"\nADAPTER_SAVE_PATH = \"/kaggle/working/nemotron_lora_adapter\"\nmodel.save_pretrained(ADAPTER_SAVE_PATH, safe_serialization=True)\ntokenizer.save_pretrained(ADAPTER_SAVE_PATH)\n\n# Report disk usage\nimport shutil\nadapter_size = sum(\n    os.path.getsize(os.path.join(dp, f))\n    for dp, _, fns in os.walk(ADAPTER_SAVE_PATH)\n    for f in fns\n) / (1024 * 1024)\ndisk_usage = shutil.disk_usage(\"/kaggle/working\")\nprint(f\"\\n💾 LoRA adapter saved to: {ADAPTER_SAVE_PATH}\")\nprint(f\"   Adapter size: {adapter_size:.1f} MB\")\nprint(f\"   Disk remaining: {disk_usage.free / (1024**3):.1f} GB\")\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"## QUICK INFERENCE TEST","metadata":{}},{"cell_type":"code","source":"print(\"\\n🧪 RUNNING INFERENCE TEST...\\n\")\n\n# Switch to evaluation mode (no Unsloth needed)\nmodel.eval()\n\ntest_prompt = REASONING_TEMPLATE.format(\n    system_prompt    = REASONING_ON_SYSTEM,\n    question         = \"If f(x) = x^2 + 3x - 4, find all values of x where f(x) = 0. Show full working.\",\n    chain_of_thought = \"\",  # Empty — model will generate this\n    final_answer     = \"\",  # Empty — model will generate this\n).split(\"<think>\")[0] + \"<think>\"  # Cut at <think> — model generates the rest\n\ninputs = tokenizer(test_prompt, return_tensors=\"pt\").to(\"cuda\")\n\nwith torch.inference_mode():\n    outputs = model.generate(\n        **inputs,\n        max_new_tokens  = 8192,\n        temperature     = 0.6,\n        top_p           = 0.95,\n        do_sample       = True,\n        eos_token_id    = tokenizer.eos_token_id,\n        repetition_penalty = 1.1\n    )\n\nresponse = tokenizer.decode(outputs[0], skip_special_tokens=False)\nprint(\"--- MODEL OUTPUT ---\")\nprint(response)\nprint(\"-------------------\")\n\n# Validate reasoning trace is present\nif \"<think>\" in response and \"</think>\" in response:\n    print(\"\\n✅ PHASE 1 MISSION SUCCESS — Reasoning trace confirmed in output.\")\nelse:\n    print(\"\\n⚠️  WARNING — No reasoning trace detected. Check dataset format.\")\n\n# Final cleanup\ndel inputs, outputs\ngc.collect()\ntorch.cuda.empty_cache()\n\nprint(\"\\n\" + \"=\"*60)\nprint(\"PHASE 1 COMPLETE. STAND BY FOR PHASE 2 ORDERS.\")\nprint(\"=\"*60)","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"markdown","source":"# SECTION-2: SPECIFIC FINE-TUNINING\n","metadata":{}}]}